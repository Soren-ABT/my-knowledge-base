---
import { siteConfig } from "../config";
import ThemeScript from "../components/ThemeScript.astro";
import CoreManager from "../components/CoreManager.astro";
import Analytics from "@vercel/analytics/astro";

const pageTitle = siteConfig.subtitle
  ? `${siteConfig.title} - ${siteConfig.subtitle}`
  : siteConfig.title;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const hue = siteConfig.themeColor.hue;
---

<!doctype html>
<html lang={siteConfig.lang.replace("_", "-")}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>{pageTitle}</title>
    <meta name="description" content={siteConfig.subtitle} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={siteConfig.subtitle} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content={siteConfig.lang.replace("-", "_")} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={siteConfig.subtitle} />
    <meta name="twitter:creator" content="@soren_abt" />

    <style define:vars={{ hue }}></style>

    <!-- Theme: centralized module (Mizuki pattern) — single source of truth -->
    <ThemeScript />

    <!-- CoreManager: centralized event delegation for all interactive UI -->
    <CoreManager />
  </head>
  <body class="welcome-page">
    <!-- Wave canvas for theme transitions -->
    <canvas id="theme-wave-canvas"></canvas>

    <!-- Loading overlay -->
    <div id="loading">
      <div class="loader-wrapper" id="loaderWrapper">
        <div class="loader-triangle" id="loaderTriangle">
          <svg viewBox="0 0 100 100">
            <polygon class="tri-bg" points="50,10 91.7,80 8.3,80"></polygon>
            <polygon class="tri-progress" points="50,10 91.7,80 8.3,80" pathLength="120"></polygon>
          </svg>
        </div>
        <div class="loading-text">LOADING</div>
      </div>
    </div>

    <slot />

    <!-- Client app logic -->
    <script defer src="/js/app.js"></script>

    <!-- Music player engine + modules (ensure loaded even when entry page is WelcomeLayout) -->
    <script defer src="/js/music-player.js"></script>
    <script defer src="/js/music-player-decoder.js"></script>
    <script defer src="/js/music-player-library.js"></script>

    <!-- Loading screen & wave animation scripts -->
    <script is:inline data-astro-rerun>
      (function () {
        "use strict";

        // ========== 加载动画 (Loader) ==========
        var LOADER_MAX_ANGLE = 9;
        var LOADER_BASE_SHADOW =
          "drop-shadow(0 0 4px rgba(0,0,0,0.15)) drop-shadow(0 0 1px rgba(0,0,0,0.3))";
        var stateLoading = false;

        var loaderWrapper = document.getElementById("loaderWrapper");
        var loaderTriangle = document.getElementById("loaderTriangle");
        var loading = document.getElementById("loading");

        function handleLoaderMouse(e) {
          if (stateLoading) return;
          var dx = (e.clientX - window.innerWidth / 2) / (window.innerWidth / 2);
          var dy = (e.clientY - window.innerHeight / 2) / (window.innerHeight / 2);
          if (loaderWrapper) {
            loaderWrapper.style.transform =
              "rotateX(" +
              -dy * LOADER_MAX_ANGLE +
              "deg) rotateY(" +
              dx * LOADER_MAX_ANGLE +
              "deg) translateZ(14px)";
          }
          if (loaderTriangle) {
            loaderTriangle.style.filter =
              LOADER_BASE_SHADOW +
              " drop-shadow(" +
              dx * 10 +
              "px " +
              dy * 10 +
              "px 12px rgba(0,0,0,0.35))";
          }
        }

        document.addEventListener("mousemove", handleLoaderMouse);

        window.__hideLoader = function () {
          if (stateLoading) return;
          stateLoading = true;
          document.removeEventListener("mousemove", handleLoaderMouse);
          if (loading) {
            loading.classList.add("fade-out");
            setTimeout(function () {
              if (loading) loading.style.display = "none";
            }, 450);
          }
        };

        // ========== 无过渡类 (no-transition) ==========
        window.__freezeTransitions = function (el) {
          el.classList.add("no-transition");
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              el.classList.remove("no-transition");
            });
          });
        };

        // ========== Theme change → wave animation ==========
        window.addEventListener("theme-change", function (e) {
          try {
            var bg =
              getComputedStyle(document.body).getPropertyValue("--wl-bg").trim() ||
              getComputedStyle(document.body).getPropertyValue("--page-bg").trim();
            if (typeof window.__animateWave === "function") {
              window.__animateWave(bg || (e.detail.dark ? "#08080f" : "#f0ede8"));
            }
          } catch (err) {}
        });
      })();
    </script>
    <script>
      import "../scripts/welcome-wave";
    </script>
    <Analytics />
  </body>
</html>
