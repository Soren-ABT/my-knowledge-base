---
import "../styles/global.css";
import "katex/dist/katex.css";
import { siteConfig } from "../config";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FullscreenWallpaper from "../components/FullscreenWallpaper.astro";
import FloatingTOC from "../components/FloatingTOC.astro";
import SettingsPanel from "../components/SettingsPanel.astro";
import MusicPlayer from "../components/MusicPlayer.astro";
import CanvasLayer from "../components/CanvasLayer.astro";
import OverlayLayer from "../components/OverlayLayer.astro";
import ConfigCarrier from "../components/ConfigCarrier.astro";
import ThemeScript from "../components/ThemeScript.astro";
import CoreManager from "../components/CoreManager.astro";
import Analytics from "@vercel/analytics/astro";
import { fullscreenWallpaperConfig } from "../config";
import { getStrings } from "../i18n";
import { ClientRouter } from "astro:transitions";

const ui = await getStrings(siteConfig.lang);

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  withProgressBar?: boolean;
  withSidebar?: boolean;
}

const { title, description, ogImage, withProgressBar = true, withSidebar = false } = Astro.props;

const pageTitle = title
  ? `${title} - ${siteConfig.title}`
  : siteConfig.subtitle
    ? `${siteConfig.title} - ${siteConfig.subtitle}`
    : siteConfig.title;

const pageDescription = description || siteConfig.subtitle || "";

const ogImageUrl = ogImage
  ? ogImage.startsWith("http")
    ? ogImage
    : new URL(ogImage, Astro.site).toString()
  : undefined;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const hue = siteConfig.themeColor.hue;
const navbarTransparentMode = siteConfig.banner?.navbar?.transparentMode || "semi";
const shouldShowTopHighlight =
  navbarTransparentMode === "full" || navbarTransparentMode === "semifull";
---

<!doctype html>
<html lang={siteConfig.lang.replace("_", "-")}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#6366f1" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:locale" content={siteConfig.lang.replace("-", "_")} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:creator" content="@soren_abt" />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <!-- Theme hue CSS variable -->
    <style define:vars={{ hue }}></style>

    <!-- Theme: centralized module (Mizuki pattern) — single source of truth -->
    <ThemeScript />

    <!-- CoreManager: centralized event delegation for all interactive UI -->
    <CoreManager />

    <!-- Font preload for self-hosted fonts -->
    <link
      rel="preload"
      href="/assets/font/JetBrainsMonoNerdFont-Light.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- CDN hints for faster third-party loading -->
    <link rel="dns-prefetch" href="//cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="//unpkg.com" />
    <link rel="preconnect" href="https://unpkg.com" crossorigin />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={siteConfig.title}
      href={`${Astro.site}rss.xml`}
    />

    <!-- global.css imported via Astro frontmatter -->

    <!-- Astro View Transitions for smooth page navigation -->
    <ClientRouter />

    <!-- MathJax config (synchronous, before any async load) -->
    <script is:inline>
      window.MathJax = {
        tex: {
          inlineMath: [
            ["$", "$"],
            ["\\(", "\\)"],
          ],
          displayMath: [
            ["$$", "$$"],
            ["\\[", "\\]"],
          ],
          processEscapes: true,
        },
        options: {
          skipHtmlTags: ["script", "noscript", "style", "textarea", "mjx-container"],
          ignoreHtmlClass: "tex2jax_ignore",
        },
      };
    </script>
    <!-- MathJax async loader with CDN fallback -->
    <script defer src="/js/mathjax-loader.js"></script>
  </head>
  <body class="min-h-screen font-sans antialiased">
    <a href="#content-wrapper" class="skip-link">{ui["common.skipToContent"]}</a>
    <!-- Critical: set wallpaper mode before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var mode = localStorage.getItem("wallpaper-mode");
        if (mode === "banner" || mode === "fullscreen" || mode === "overlay") {
          document.body.classList.add("wallpaper-transparent");
        }
        var s = document.documentElement.style;
        var op = localStorage.getItem("overlay-opacity");
        var bl = localStorage.getItem("overlay-blur");
        var co = localStorage.getItem("overlay-card-opacity");
        if (op) s.setProperty("--wallpaper-opacity", Number(op) / 100);
        if (bl) s.setProperty("--wallpaper-blur", bl + "px");
        if (co) s.setProperty("--card-transparent-opacity", Number(co) / 100);
      })();
    </script>

    <!-- Top gradient highlight for transparent navbar -->
    {shouldShowTopHighlight && <div class="top-gradient-highlight" />}

    <!-- Fullscreen wallpaper -->
    {fullscreenWallpaperConfig.enable && <FullscreenWallpaper config={fullscreenWallpaperConfig} />}

    <!-- Canvas layer: theme wave + sakura particles -->
    <CanvasLayer />

    <!-- Music Player -->
    <MusicPlayer />

    {withProgressBar && siteConfig.pageProgressBar.enable && <div id="page-progress-bar" />}

    <!-- Navbar -->
    <div
      id="top-row"
      class="z-50 pointer-events-none relative transition-all duration-700 max-w-6xl px-0 md:px-4 mx-auto"
    >
      <div id="navbar-wrapper" class="pointer-events-auto sticky top-0 transition-all">
        <Navbar transparentMode={navbarTransparentMode} />
      </div>
    </div>

    <main
      id="content-wrapper"
      class="onload-animation mx-auto max-w-6xl px-4 py-8 sm:px-6"
      transition:animate="fade"
      data-pagefind-body
    >
      <slot />
    </main>

    <Footer />

    <!-- Overlay layer: modals, lightbox, search, toc, settings -->
    <OverlayLayer />
    <FloatingTOC />
    <SettingsPanel />

    <!-- Client app logic: processed by Vite for bundling + hashing -->
    <script src="../scripts/client/app.ts"></script>

    <!-- MathJax re-typeset on client-side navigation -->
    <script defer src="/js/mathjax-retypeset.js"></script>

    <!-- Sakura particle effect: external for better caching -->
    <script defer src="/js/sakura.js"></script>

    <!-- Music player engine + modules -->
    <script defer src="/js/music-player.js"></script>
    <script defer src="/js/music-player-decoder.js"></script>
    <script defer src="/js/music-player-library.js"></script>
    <!-- Mermaid diagram renderer -->
    <script defer src="/js/mermaid-render.js"></script>

    <!-- Config carrier: passes server config to client-side scripts -->
    <ConfigCarrier />

    <!-- Vercel Analytics: Web Vitals + traffic insights -->
    <Analytics />
  </body>
</html>
