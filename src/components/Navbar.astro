---
import { profileConfig, siteConfig, navBarConfig } from "../config";
import { getStrings } from "../i18n";

const ui = await getStrings(siteConfig.lang);

interface Props {
  transparentMode?: "semi" | "full" | "semifull";
}

const { transparentMode = "semifull" } = Astro.props;
---

<header
  id="navbar"
  data-transparent-mode={transparentMode}
  data-is-home={Astro.url.pathname === "/" || Astro.url.pathname === "" ? "true" : "false"}
  class="z-50 onload-animation"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
    <a
      href="/"
      class="flex items-center gap-3 text-lg font-bold no-underline transition-opacity hover:opacity-80"
    >
      {
        profileConfig.avatar && (
          <img
            src={profileConfig.avatar}
            alt={profileConfig.name}
            class="h-8 w-8 rounded-full ring-2 ring-[var(--border-color)]"
          />
        )
      }
      <span
        class="bg-gradient-to-r from-[var(--primary)] to-[var(--progress-color-end)] bg-clip-text text-transparent"
      >
        {siteConfig.title}
      </span>
    </a>

    <div class="flex items-center gap-0.5 sm:gap-1">
      <a href="/posts/" class="nav-link">{ui["nav.posts"]}</a>
      <a href="/archive/" class="nav-link">{ui["nav.archive"]}</a>
      <a href="/tags/" class="nav-link">{ui["nav.tags"]}</a>
      <a href="/gallery/" class="nav-link">{ui["nav.gallery"]}</a>
      <a href="/docs/" class="nav-link">{ui["nav.docs"]}</a>
      <a href="/about/" class="nav-link">{ui["nav.about"]}</a>

      <div class="mx-1.5 h-5 w-px bg-[var(--line-divider)]" aria-hidden="true"></div>

      {
        navBarConfig.search && (
          <button id="search-trigger-btn" class="nav-icon-btn" aria-label="搜索">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <>
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.3-4.3" />
              </>
            </svg>
          </button>
        )
      }
      {
        navBarConfig.rss && (
          <a href="/rss.xml" class="nav-icon-btn" aria-label="RSS" target="_blank">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <>
                <path d="M4 11a9 9 0 0 1 9 9" />
                <path d="M4 4a16 16 0 0 1 16 16" />
                <circle cx="5" cy="19" r="1" />
              </>
            </svg>
          </a>
        )
      }
      {
        navBarConfig.themeToggle && (
          <button id="theme-toggle-btn" class="nav-icon-btn" aria-label="切换主题">
            <svg
              class="sun-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <>
                <circle cx="12" cy="12" r="5" />
                <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
              </>
            </svg>
            <svg
              class="moon-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
          </button>
        )
      }
    </div>
  </div>
</header>

<style>
  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    transition:
      color 0.2s,
      background-color 0.2s;
  }
  .nav-link:hover {
    color: var(--text-color);
    background-color: var(--btn-plain-bg-hover);
  }
  .nav-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition:
      color 0.2s,
      background-color 0.2s;
  }
  .nav-icon-btn:hover {
    color: var(--text-color);
    background-color: var(--btn-plain-bg-hover);
  }
  .sun-icon,
  .moon-icon {
    transition: opacity 0.2s;
  }
  :global(.dark) .sun-icon {
    display: none;
  }
  :global(:not(.dark)) .moon-icon {
    display: none;
  }
</style>

<!-- Theme toggle handled by CoreManager.astro (head) — Mizuki event delegation pattern -->
