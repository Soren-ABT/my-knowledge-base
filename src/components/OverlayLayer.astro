---
// OverlayLayer — modal overlays and floating UI elements
// Extracted from Layout.astro to keep the main template lean.
// These are static DOM containers; all interactivity is driven by app.js.
---
<!-- Toast container -->
<div id="toast-container"></div>

<!-- Back to top -->
<button id="back-to-top" aria-label="回到顶部">
  <svg viewBox="0 0 24 24"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
</button>

<!-- Search modal -->
<div class="search-modal-overlay float-panel-closed" id="searchModalOverlay">
  <div class="search-modal" role="search">
    <div class="search-modal-header">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" class="search-modal-input" id="searchModalInput" placeholder="搜索… (Ctrl+K 或 /)" aria-label="搜索" />
      <button class="search-modal-close" id="searchModalClose" aria-label="关闭搜索"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" fill="none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div class="search-hint" aria-live="polite">↑↓ 导航 · Enter 跳转 · Esc 关闭</div>
    <div class="search-results" id="searchResults" role="listbox"></div>
  </div>
</div>

<!-- Image lightbox -->
<div id="img-lightbox" role="dialog" aria-label="图片预览">
  <button class="lb-close" aria-label="关闭">&times;</button>
  <img src="" alt="preview" />
</div>

<!-- Link preview card -->
<div class="link-preview-card" id="linkPreviewCard">
  <div class="lp-loader">Loading preview...</div>
</div>

<!-- Shortcuts panel -->
<div id="shortcuts-panel" class="float-panel-closed">
  <div class="shortcuts-modal" role="dialog" aria-label="快捷键帮助">
    <h3>键盘快捷键</h3>
    <div class="kbd-row"><span>全局搜索</span><span><kbd>Ctrl</kbd>+<kbd>K</kbd></span></div>
    <div class="kbd-row"><span>快速搜索</span><span><kbd>/</kbd></span></div>
    <div class="kbd-row"><span>暗色模式</span><span><kbd>Ctrl</kbd>+<kbd>D</kbd></span></div>
    <div class="kbd-row"><span>回到顶部</span><span><kbd>Ctrl</kbd>+<kbd>↑</kbd></span></div>
    <div class="kbd-row"><span>关闭面板</span><span><kbd>Esc</kbd></span></div>
    <div class="kbd-row"><span>帮助</span><span><kbd>?</kbd></span></div>
  </div>
</div>
