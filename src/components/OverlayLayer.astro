---
import { siteConfig } from "../config";
import { getStrings } from "../i18n";

const ui = await getStrings(siteConfig.lang);
---
<!-- Toast container -->
<div id="toast-container"></div>

<!-- Back to top -->
<button id="back-to-top" aria-label={ui["common.backToTop"]}>
  <svg viewBox="0 0 24 24"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
</button>

<!-- Search modal -->
<div class="search-modal-overlay float-panel-closed" id="searchModalOverlay">
  <div class="search-modal" role="search">
    <div class="search-modal-header">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="text" class="search-modal-input" id="searchModalInput" placeholder={ui["search.placeholder"]} aria-label={ui["search.title"]} />
      <button class="search-modal-close" id="searchModalClose" aria-label="关闭搜索"><svg width="18" height="18" viewBox="0 0 24 24" stroke="currentColor" fill="none"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    </div>
    <div class="search-hint" aria-live="polite">{ui["search.hint"]}</div>
    <div class="search-results" id="searchResults" role="listbox"></div>
  </div>
</div>

<!-- Image lightbox -->
<div id="img-lightbox" role="dialog" aria-label="图片预览">
  <button class="lb-close" aria-label="关闭">&times;</button>
  <img src="" alt="preview" />
</div>

<!-- Link preview card -->
<div class="link-preview-card" id="linkPreviewCard">
  <div class="lp-loader">Loading preview...</div>
</div>

<!-- Shortcuts panel -->
<div id="shortcuts-panel" class="float-panel-closed">
  <div class="shortcuts-modal" role="dialog" aria-label="快捷键帮助">
    <h3>{ui["shortcuts.title"]}</h3>
    <div class="kbd-row"><span>{ui["shortcuts.globalSearch"]}</span><span><kbd>Ctrl</kbd>+<kbd>K</kbd></span></div>
    <div class="kbd-row"><span>{ui["shortcuts.quickSearch"]}</span><span><kbd>/</kbd></span></div>
    <div class="kbd-row"><span>{ui["shortcuts.darkMode"]}</span><span><kbd>Ctrl</kbd>+<kbd>D</kbd></span></div>
    <div class="kbd-row"><span>{ui["shortcuts.backToTopKbd"]}</span><span><kbd>Ctrl</kbd>+<kbd>↑</kbd></span></div>
    <div class="kbd-row"><span>{ui["shortcuts.closePanel"]}</span><span><kbd>Esc</kbd></span></div>
    <div class="kbd-row"><span>{ui["shortcuts.help"]}</span><span><kbd>?</kbd></span></div>
  </div>
</div>
