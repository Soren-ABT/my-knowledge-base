<!-- ============================================
     Full-Screen Immersive Playback (Roon-inspired)
     ============================================ -->
<div class="music-immersive-overlay" id="music-immersive-overlay" style="display:none">
  <!-- Layered background -->
  <div class="music-immersive-bg" id="music-immersive-bg">
    <div class="bg-layer back" id="music-immersive-bg-back"></div>
    <div class="bg-layer front" id="music-immersive-bg-front"></div>
  </div>
  <!-- Dimming -->
  <div class="music-immersive-dimming"></div>
  <!-- Close button -->
  <button class="music-immersive-close" id="music-immersive-close" aria-label="关闭沉浸模式"
    >&times;</button
  >
  <!-- Content -->
  <div class="music-immersive-main">
    <!-- Album art -->
    <div class="music-immersive-artwork" id="music-immersive-artwork">
      <img src="" alt="" />
    </div>
    <!-- Track info -->
    <div class="music-immersive-info">
      <div class="music-immersive-title" id="music-immersive-title">--</div>
      <div class="music-immersive-artist" id="music-immersive-artist">--</div>
      <div class="music-immersive-album" id="music-immersive-album"></div>
      <div class="music-immersive-quality" id="music-immersive-quality"></div>
    </div>
    <!-- Progress -->
    <div class="music-immersive-progress">
      <canvas class="music-immersive-spectrum" id="music-immersive-spectrum"></canvas>
      <div class="music-immersive-progress-bar" id="music-immersive-progress-bar">
        <div class="music-immersive-progress-fill" id="music-immersive-progress-fill"></div>
        <div class="music-immersive-progress-thumb" id="music-immersive-progress-thumb"></div>
      </div>
      <div class="music-immersive-progress-tooltip" id="music-immersive-progress-tooltip" hidden>
        0:00
      </div>
      <div class="music-immersive-times">
        <span id="music-immersive-current">0:00</span>
        <span id="music-immersive-duration">0:00</span>
      </div>
    </div>
    <!-- Controls -->
    <div class="music-immersive-controls">
      <button class="music-immersive-btn" id="music-immersive-shuffle" title="随机播放">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          width="18"
          height="18"
        >
          <path d="M16 3h5v5M4 20 21 3M21 16v5h-5M15 15l6 6M4 4l5 5"></path>
        </svg>
      </button>
      <button class="music-immersive-btn" id="music-immersive-prev" title="上一首">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"></path>
        </svg>
      </button>
      <button
        class="music-immersive-btn music-immersive-btn-play"
        id="music-immersive-play"
        title="播放/暂停"
      >
        <svg
          id="music-immersive-icon-play"
          viewBox="0 0 24 24"
          fill="currentColor"
          width="24"
          height="24"
        >
          <path d="M8 5v14l11-7z"></path>
        </svg>
        <svg
          id="music-immersive-icon-pause"
          viewBox="0 0 24 24"
          fill="currentColor"
          width="24"
          height="24"
          style="display:none"
        >
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"></path>
        </svg>
      </button>
      <button class="music-immersive-btn" id="music-immersive-next" title="下一首">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
          <path d="M16 18h2V6h-2zm-11-7 8.5 6V6z"></path>
        </svg>
      </button>
      <button class="music-immersive-btn" id="music-immersive-repeat" title="循环模式">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          width="18"
          height="18"
        >
          <path d="M17 2l4 4-4 4"></path>
          <path d="M3 11v-1a4 4 0 0 1 4-4h14"></path>
          <path d="M7 22l-4-4 4-4"></path>
          <path d="M21 13v1a4 4 0 0 1-4 4H3"></path>
        </svg>
      </button>
    </div>
  </div>
</div>
