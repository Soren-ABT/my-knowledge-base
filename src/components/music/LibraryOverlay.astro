<!-- ============================================
     Music Library Overlay — Apple Music-style layout
     ============================================ -->
<div class="music-library-overlay" id="music-library-overlay" style="display:none">
  <div class="music-library-container">
    <!-- Sidebar -->
    <aside class="music-library-sidebar" id="music-library-sidebar">
      <div class="music-library-sidebar-brand">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          width="24"
          height="24"
        >
          <path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle
            cx="18"
            cy="16"
            r="3"></circle>
        </svg>
        <span class="music-library-sidebar-brand-text">音乐库</span>
      </div>
      <nav class="music-library-sidebar-nav" id="music-lib-sidebar-nav"></nav>
    </aside>

    <!-- Main content -->
    <div class="music-library-main">
      <!-- Top bar -->
      <div class="music-library-topbar">
        <div class="music-library-topbar-left">
          <button
            class="music-library-back-btn"
            id="music-lib-back"
            title="返回"
            aria-label="返回"
            style="visibility:hidden"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="20"
              height="20"
            >
              <path d="M19 12H5m7-7-7 7 7 7"></path>
            </svg>
          </button>
          <span class="music-library-title" id="music-lib-title">浏览</span>
        </div>
        <div class="music-library-topbar-right">
          <div class="music-library-search-wrapper">
            <svg
              class="music-library-search-icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="16"
              height="16"
            >
              <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path>
            </svg>
            <input
              type="text"
              class="music-library-search"
              id="music-lib-search"
              placeholder="搜索音乐库…"
              aria-label="搜索音乐"
            />
          </div>
          <div class="music-library-view-toggles" id="music-lib-view-toggles">
            <button
              class="music-library-view-btn active"
              id="music-lib-view-grid"
              title="专辑视图"
              aria-label="专辑视图"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                <rect x="3" y="3" width="7" height="7" rx="1"></rect><rect
                  x="14"
                  y="3"
                  width="7"
                  height="7"
                  rx="1"></rect>
                <rect x="3" y="14" width="7" height="7" rx="1"></rect><rect
                  x="14"
                  y="14"
                  width="7"
                  height="7"
                  rx="1"></rect>
              </svg>
            </button>
            <button
              class="music-library-view-btn"
              id="music-lib-view-list"
              title="列表视图"
              aria-label="列表视图"
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                width="16"
                height="16"
              >
                <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"></path>
              </svg>
            </button>
          </div>
          <div class="music-library-sort-wrapper">
            <select class="music-library-sort-select" id="music-lib-sort" aria-label="排序">
              <option value="album">专辑</option>
              <option value="title">曲名</option>
              <option value="artist">艺术家</option>
              <option value="year">年份</option>
              <option value="duration">时长</option>
              <option value="plays">播放次数</option>
            </select>
          </div>
          <button
            class="music-library-refresh-btn"
            id="music-lib-refresh"
            title="刷新音乐库"
            aria-label="刷新音乐库"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="16"
              height="16"
            >
              <path
                d="M21 2v6h-6M3 12a9 9 0 0 1 15.36-5.64L21 9M3 22v-6h6M21 12a9 9 0 0 1-15.36 5.64L3 15"
              ></path>
            </svg>
          </button>
          <button
            class="music-library-close-btn"
            id="music-lib-close"
            title="关闭"
            aria-label="关闭音乐库"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              width="18"
              height="18"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>

      <!-- Content area -->
      <div class="music-library-content" id="music-lib-content">
        <div class="music-lib-empty">加载中…</div>
      </div>

      <!-- Now-playing mini bar -->
      <div class="music-lib-nowplaying-bar" id="music-lib-nowplaying-bar" style="display:none">
        <div class="music-lib-np-progress">
          <div class="music-lib-np-progress-fill" id="music-lib-np-progress-fill"></div>
        </div>
        <div class="music-lib-np-cover">
          <img src="" alt="" />
        </div>
        <div class="music-lib-np-info">
          <div class="music-lib-np-title"></div>
          <div class="music-lib-np-artist"></div>
        </div>
        <div class="music-lib-np-time"></div>
      </div>
    </div>
  </div>
</div>
