---
import { musicPlayerConfig } from "../config/musicPlayerConfig";
import "../styles/music-player/core.css";

const show = musicPlayerConfig.enable && musicPlayerConfig.showFloatingPlayer;
const playlist = musicPlayerConfig.playlist;
---

{show && playlist.length > 0 && (
  <>
    {/* FAB button */}
    <button
      id="music-fab"
      class="music-fab"
      aria-label="音乐控制中心"
      title="音乐控制中心"
    >
      <svg class="music-fab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 18V5l12-2v13"/>
        <circle cx="6" cy="18" r="3"/>
        <circle cx="18" cy="16" r="3"/>
      </svg>
      <span class="music-fab-dot" id="music-fab-dot" hidden></span>
    </button>

    <!-- Expanded panel -->
    <div id="music-panel" class="music-panel float-panel-closed" aria-label="音乐播放器" style="display:none">
      <div class="music-panel-cover">
        <img
          id="music-cover"
          src=""
          alt="专辑封面"
          class="music-cover-img"
          crossorigin="anonymous"
        />
      </div>
      <div class="music-panel-info">
        <div class="music-panel-title" id="music-title">--</div>
        <div class="music-panel-artist" id="music-artist">--</div>
        <div class="music-panel-decoder">
          <span class="music-decoder-badge" id="music-decoder-badge" hidden></span>
          <span class="music-decoder-codec" id="music-decoder-codec"></span>
        </div>
        <div class="music-panel-dsp" id="music-panel-dsp" hidden>
          <span class="music-dsp-dot" id="music-dsp-dot"></span>
          <span class="music-dsp-path" id="music-dsp-path"></span>
        </div>
      </div>
      <div class="music-panel-progress">
        <canvas class="music-spectrum-canvas" id="music-spectrum-canvas"></canvas>
        <div
          class="music-progress-bar"
          id="music-progress-bar"
          role="slider"
          aria-label="播放进度"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-valuenow="0"
        >
          <div class="music-progress-fill" id="music-progress-fill"></div>
          <div class="music-progress-thumb" id="music-progress-thumb"></div>
        </div>
        <div class="music-progress-tooltip" id="music-progress-tooltip" hidden>0:00</div>
        <div class="music-time-row">
          <span id="music-current-time">0:00</span>
          <span id="music-duration">0:00</span>
        </div>
      </div>
      <div class="music-panel-controls">
        <button class="music-btn" id="music-btn-library" title="音乐库" aria-label="音乐库">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="15" height="15">
            <rect x="3" y="3" width="7" height="7" rx="1"/>
            <rect x="14" y="3" width="7" height="7" rx="1"/>
            <rect x="3" y="14" width="7" height="7" rx="1"/>
            <rect x="14" y="14" width="7" height="7" rx="1"/>
          </svg>
        </button>
        <button class="music-btn" id="music-btn-shuffle" title="随机播放" aria-label="随机播放">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
            <path d="M16 3h5v5M4 20 21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/>
          </svg>
        </button>
        <button class="music-btn" id="music-btn-prev" title="上一首" aria-label="上一首">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/>
          </svg>
        </button>
        <button class="music-btn music-btn-play" id="music-btn-play" title="播放/暂停" aria-label="播放/暂停">
          <svg id="music-icon-play" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg id="music-icon-pause" viewBox="0 0 24 24" fill="currentColor" width="22" height="22" style="display:none">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
          </svg>
        </button>
        <button class="music-btn" id="music-btn-next" title="下一首" aria-label="下一首">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
            <path d="M16 18h2V6h-2zm-11-7 8.5 6V6z"/>
          </svg>
        </button>
        <button class="music-btn" id="music-btn-repeat" title="循环模式" aria-label="循环模式">
          <svg id="music-icon-repeat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
            <path d="M17 2l4 4-4 4"/>
            <path d="M3 11v-1a4 4 0 0 1 4-4h14"/>
            <path d="M7 22l-4-4 4-4"/>
            <path d="M21 13v1a4 4 0 0 1-4 4H3"/>
          </svg>
          <span id="music-repeat-one" hidden>1</span>
        </button>
        <button class="music-btn" id="music-btn-list" title="播放列表" aria-label="播放列表">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16">
            <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
          </svg>
        </button>
      </div>
<div class="music-volume-row">
        <button class="music-btn" id="music-btn-volume" title="静音" aria-label="静音">
          <svg id="music-icon-volume" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14">
            <path d="M11 5 6 9H2v6h4l5 4V5z"/>
            <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/>
          </svg>
          <svg id="music-icon-mute" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14" style="display:none">
            <path d="M11 5 6 9H2v6h4l5 4V5z"/>
            <line x1="23" y1="9" x2="17" y2="15"/>
            <line x1="17" y1="9" x2="23" y2="15"/>
          </svg>
        </button>
        <div class="music-volume-slider" id="music-volume-slider" role="slider" aria-label="音量" aria-valuemin="0" aria-valuemax="100" aria-valuenow="70">
          <div class="music-volume-fill" id="music-volume-fill"></div>
        </div>
      </div>

      <!-- Playlist panel -->
      <div class="music-playlist" id="music-playlist" hidden>
        {playlist.map((song, idx) => (
          <div class="music-playlist-item" data-index={idx}>
            <span class="music-playlist-title">{song.title}</span>
            <span class="music-playlist-artist">{song.artist}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Error toast -->
    <div class="music-error" id="music-error" hidden>
      <span id="music-error-msg"></span>
      <button id="music-error-close" aria-label="关闭">&times;</button>
    </div>

    <!-- ============================================
         Music Library Overlay — Apple Music-style layout
         ============================================ -->
    <div class="music-library-overlay" id="music-library-overlay" style="display:none">
      <div class="music-library-container">
        <!-- Sidebar -->
        <aside class="music-library-sidebar" id="music-library-sidebar">
          <div class="music-library-sidebar-brand">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="24" height="24">
              <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
            </svg>
            <span class="music-library-sidebar-brand-text">音乐库</span>
          </div>
          <nav class="music-library-sidebar-nav" id="music-lib-sidebar-nav"></nav>
        </aside>

        <!-- Main content -->
        <div class="music-library-main">
          <!-- Top bar -->
          <div class="music-library-topbar">
            <div class="music-library-topbar-left">
              <button class="music-library-back-btn" id="music-lib-back" title="返回" aria-label="返回" style="visibility:hidden">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                  <path d="M19 12H5m7-7-7 7 7 7"/>
                </svg>
              </button>
              <span class="music-library-title" id="music-lib-title">浏览</span>
            </div>
            <div class="music-library-topbar-right">
              <div class="music-library-search-wrapper">
                <svg class="music-library-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
                </svg>
                <input type="text" class="music-library-search" id="music-lib-search" placeholder="搜索音乐库…" aria-label="搜索音乐" />
              </div>
              <div class="music-library-view-toggles" id="music-lib-view-toggles">
                <button class="music-library-view-btn active" id="music-lib-view-grid" title="专辑视图" aria-label="专辑视图">
                  <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                    <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                  </svg>
                </button>
                <button class="music-library-view-btn" id="music-lib-view-list" title="列表视图" aria-label="列表视图">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/>
                  </svg>
                </button>
              </div>
              <div class="music-library-sort-wrapper">
                <select class="music-library-sort-select" id="music-lib-sort" aria-label="排序">
                  <option value="album">专辑</option>
                  <option value="title">曲名</option>
                  <option value="artist">艺术家</option>
                  <option value="year">年份</option>
                  <option value="duration">时长</option>
                  <option value="plays">播放次数</option>
                </select>
              </div>
              <button class="music-library-refresh-btn" id="music-lib-refresh" title="刷新音乐库" aria-label="刷新音乐库">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M21 2v6h-6M3 12a9 9 0 0 1 15.36-5.64L21 9M3 22v-6h6M21 12a9 9 0 0 1-15.36 5.64L3 15"/>
                </svg>
              </button>
              <button class="music-library-close-btn" id="music-lib-close" title="关闭" aria-label="关闭音乐库">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Content area -->
          <div class="music-library-content" id="music-lib-content">
            <div class="music-lib-empty">加载中…</div>
          </div>

          <!-- Now-playing mini bar -->
          <div class="music-lib-nowplaying-bar" id="music-lib-nowplaying-bar" style="display:none">
            <div class="music-lib-np-progress">
              <div class="music-lib-np-progress-fill" id="music-lib-np-progress-fill"></div>
            </div>
            <div class="music-lib-np-cover">
              <img src="" alt="" />
            </div>
            <div class="music-lib-np-info">
              <div class="music-lib-np-title"></div>
              <div class="music-lib-np-artist"></div>
            </div>
            <div class="music-lib-np-time"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ============================================
         Full-Screen Immersive Playback (Roon-inspired)
         ============================================ -->
    <div class="music-immersive-overlay" id="music-immersive-overlay" style="display:none">
      <!-- Layered background -->
      <div class="music-immersive-bg" id="music-immersive-bg">
        <div class="bg-layer back" id="music-immersive-bg-back"></div>
        <div class="bg-layer front" id="music-immersive-bg-front"></div>
      </div>
      <!-- Dimming -->
      <div class="music-immersive-dimming"></div>
      <!-- Close button -->
      <button class="music-immersive-close" id="music-immersive-close" aria-label="关闭沉浸模式">&times;</button>
      <!-- Content -->
      <div class="music-immersive-main">
        <!-- Album art -->
        <div class="music-immersive-artwork" id="music-immersive-artwork">
          <img src="" alt="" />
        </div>
        <!-- Track info -->
        <div class="music-immersive-info">
          <div class="music-immersive-title" id="music-immersive-title">--</div>
          <div class="music-immersive-artist" id="music-immersive-artist">--</div>
          <div class="music-immersive-album" id="music-immersive-album"></div>
          <div class="music-immersive-quality" id="music-immersive-quality"></div>
        </div>
        <!-- Progress -->
        <div class="music-immersive-progress">
          <canvas class="music-immersive-spectrum" id="music-immersive-spectrum"></canvas>
          <div class="music-immersive-progress-bar" id="music-immersive-progress-bar">
            <div class="music-immersive-progress-fill" id="music-immersive-progress-fill"></div>
            <div class="music-immersive-progress-thumb" id="music-immersive-progress-thumb"></div>
          </div>
          <div class="music-immersive-progress-tooltip" id="music-immersive-progress-tooltip" hidden>0:00</div>
          <div class="music-immersive-times">
            <span id="music-immersive-current">0:00</span>
            <span id="music-immersive-duration">0:00</span>
          </div>
        </div>
        <!-- Controls -->
        <div class="music-immersive-controls">
          <button class="music-immersive-btn" id="music-immersive-shuffle" title="随机播放">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <path d="M16 3h5v5M4 20 21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/>
            </svg>
          </button>
          <button class="music-immersive-btn" id="music-immersive-prev" title="上一首">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"/>
            </svg>
          </button>
          <button class="music-immersive-btn music-immersive-btn-play" id="music-immersive-play" title="播放/暂停">
            <svg id="music-immersive-icon-play" viewBox="0 0 24 24" fill="currentColor" width="24" height="24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg id="music-immersive-icon-pause" viewBox="0 0 24 24" fill="currentColor" width="24" height="24" style="display:none">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>
          <button class="music-immersive-btn" id="music-immersive-next" title="下一首">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M16 18h2V6h-2zm-11-7 8.5 6V6z"/>
            </svg>
          </button>
          <button class="music-immersive-btn" id="music-immersive-repeat" title="循环模式">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18">
              <path d="M17 2l4 4-4 4"/>
              <path d="M3 11v-1a4 4 0 0 1 4-4h14"/>
              <path d="M7 22l-4-4 4-4"/>
              <path d="M21 13v1a4 4 0 0 1-4 4H3"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

<!-- Config carrier: playlist data via data attribute (Astro evaluates HTML attributes) -->
    <div id="music-player-config" style="display:none" data-playlist={JSON.stringify(playlist)}></div>

    <!-- Init player engine (self-contained: loads dependencies if needed) -->
    <script is:inline>
      (function() {
        function fireInit() {
          var el = document.getElementById('music-player-config');
          var playlist = [];
          try { playlist = JSON.parse(el?.dataset.playlist || '[]'); } catch(e) {}
          if (!playlist.length) return;
          document.dispatchEvent(new CustomEvent('music-player:init', { detail: { playlist: playlist } }));
        }

        function ensureEngine(cb) {
          if (window.__musicPlayer) { cb(); return; }
          var sources = ['/js/music-player.js', '/js/music-player-decoder.js', '/js/music-player-library.js'];
          var pending = sources.length;
          var failed = false;
          sources.forEach(function(src) {
            if (document.querySelector('script[src="' + src + '"]')) {
              pending--;
              if (pending === 0 && !failed) cb();
              return;
            }
            var s = document.createElement('script');
            s.src = src;
            s.onload = function() {
              pending--;
              if (pending === 0 && !failed) cb();
            };
            s.onerror = function() {
              failed = true;
            };
            document.head.appendChild(s);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function() {
            ensureEngine(fireInit);
          });
        } else {
          ensureEngine(fireInit);
        }
      })();
    </script>
  </>
)}



<script is:inline>
  (function() {
    // Guard: only run once even with Astro page swaps (is:inline re-runs)
    if (window.__musicPlayerUI) return;
    var _ui = { _cleanupFns: [] };
    window.__musicPlayerUI = _ui;

    // Collect DOM refs eagerly (elements exist now)
    var fab = document.getElementById('music-fab');
    if (!fab) return; // player not rendered on this page

    var panel = document.getElementById('music-panel');
    var cover = document.getElementById('music-cover');
    var titleEl = document.getElementById('music-title');
    var artistEl = document.getElementById('music-artist');
    var progressBar = document.getElementById('music-progress-bar');
    var progressFill = document.getElementById('music-progress-fill');
    var progressThumb = document.getElementById('music-progress-thumb');
    var progressTooltip = document.getElementById('music-progress-tooltip');
    var spectrumCanvas = document.getElementById('music-spectrum-canvas');
    var currentTimeEl = document.getElementById('music-current-time');
    var durationEl = document.getElementById('music-duration');
    var volumeSlider = document.getElementById('music-volume-slider');
    var volumeFill = document.getElementById('music-volume-fill');
    var playlistEl = document.getElementById('music-playlist');
    var errorEl = document.getElementById('music-error');
    var errorMsg = document.getElementById('music-error-msg');
    var errorClose = document.getElementById('music-error-close');
    var fabDot = document.getElementById('music-fab-dot');
    var iconPlay = document.getElementById('music-icon-play');
    var iconPause = document.getElementById('music-icon-pause');
    var iconVolume = document.getElementById('music-icon-volume');
    var iconMute = document.getElementById('music-icon-mute');
    var repeatOne = document.getElementById('music-repeat-one');
    var decoderBadge = document.getElementById('music-decoder-badge');
    var decoderCodec = document.getElementById('music-decoder-codec');
    var dspIndicator = document.getElementById('music-panel-dsp');
    var dspPath = document.getElementById('music-dsp-path');

    var expanded = false;
    var unsub = null;

    function formatTime(s) {
      s = Math.floor(s || 0);
      return Math.floor(s / 60) + ':' + ('0' + (s % 60)).slice(-2);
    }

    function updateUI(s) {
      // Cover image (only if cover element exists)
      if (cover) {
        if (s.currentSong.cover) {
          cover.src = s.currentSong.cover;
        } else {
          cover.src = '/favicon.ico';
        }
      }

      titleEl.textContent = s.currentSong.title || '--';
      artistEl.textContent = s.currentSong.artist || '--';

      // Decoder badge (Roon-style quality indicator)
      if (s.currentSong.qualityBadge) {
        var tierColors = {
          studioMaster: '#ffd700', hiRes: '#ff8c00', cdQuality: '#4caf50',
          lossless: '#2196f3', highLossy: '#ff9800', standardLossy: '#9e9e9e', lowLossy: '#757575'
        };
        decoderBadge.hidden = false;
        decoderBadge.textContent = s.currentSong.qualityBadge;
        decoderBadge.style.background = tierColors[s.currentSong.qualityTier] || '#888';
        decoderBadge.style.color = ['studioMaster', 'hiRes', 'highLossy'].indexOf(s.currentSong.qualityTier) >= 0 ? '#000' : '#fff';
      } else {
        decoderBadge.hidden = true;
      }
      if (s.currentSong.codec || s.currentSong.sampleRate) {
        var parts = [];
        if (s.currentSong.codecName) parts.push(s.currentSong.codecName);
        else if (s.currentSong.codec) parts.push(s.currentSong.codec.toUpperCase());
        if (s.currentSong.sampleRate) {
          parts.push((s.currentSong.sampleRate / 1000).toFixed(s.currentSong.sampleRate % 1000 === 0 ? 0 : 1) + 'kHz');
        }
        if (s.currentSong.bitsPerSample) parts.push(s.currentSong.bitsPerSample + 'bit');
        decoderCodec.textContent = parts.join(' · ');
      } else {
        decoderCodec.textContent = '';
      }

      // DSP signal path indicator
      if (dspIndicator && dspPath) {
        var dspChain = window.__musicPlayer.getDspChain();
        if (dspChain && dspChain.activeCount > 0) {
          dspIndicator.hidden = false;
          dspPath.textContent = dspChain.path;
        } else {
          dspIndicator.hidden = true;
        }
      }

      var pct = s.duration > 0 ? (s.currentTime / s.duration) * 100 : 0;
      if (progressFill) progressFill.style.width = pct + '%';
      if (progressThumb) progressThumb.style.left = pct + '%';
      if (currentTimeEl) currentTimeEl.textContent = formatTime(s.currentTime);
      if (durationEl) durationEl.textContent = formatTime(s.duration);

      iconPlay.hidden = s.isPlaying;
      iconPause.hidden = !s.isPlaying;

      if (s.isPlaying) {
        fab.classList.add('playing');
        fabDot.hidden = false;
      } else {
        fab.classList.remove('playing');
        fabDot.hidden = true;
      }

      document.getElementById('music-btn-shuffle').classList.toggle('active', s.isShuffled);
      var repeatBtn = document.getElementById('music-btn-repeat');
      repeatBtn.classList.toggle('active', s.isRepeating !== 0);
      repeatOne.hidden = s.isRepeating !== 1;

      volumeFill.style.width = (s.volume * 100) + '%';
      iconVolume.hidden = s.isMuted || s.volume === 0;
      iconMute.hidden = !s.isMuted && s.volume !== 0;

      // Update playlist items
      var items = playlistEl.querySelectorAll('.music-playlist-item');
      items.forEach(function(item) {
        item.classList.toggle('current', parseInt(item.dataset.index) === s.currentIndex);
      });

      // Error
      if (s.showError) {
        errorMsg.textContent = s.errorMessage;
        errorEl.hidden = false;
      } else {
        errorEl.hidden = true;
      }
    }

    function openPanel() {
      expanded = true;
      panel.style.display = '';
      panel.classList.remove('float-panel-closed');
    }

    function closePanel() {
      expanded = false;
      panel.classList.add('float-panel-closed');
      setTimeout(function() {
        if (!expanded) panel.style.display = 'none';
      }, 300);
    }

    function setup(player) {
      // FAB click
      fab.addEventListener('click', function(e) {
        e.stopPropagation();
        expanded ? closePanel() : openPanel();
      });

      // Play/pause
      document.getElementById('music-btn-play').addEventListener('click', function() {
        player.toggle();
      });

      // Prev/next
      document.getElementById('music-btn-prev').addEventListener('click', function() { player.prev(); });
      document.getElementById('music-btn-next').addEventListener('click', function() { player.next(); });

      // Shuffle
      document.getElementById('music-btn-shuffle').addEventListener('click', function() { player.toggleShuffle(); });

      // Repeat
      document.getElementById('music-btn-repeat').addEventListener('click', function() { player.toggleRepeat(); });

      // Playlist toggle — directly toggle hidden attribute
      document.getElementById('music-btn-list').addEventListener('click', function(e) {
        e.stopPropagation();
        var pl = document.getElementById('music-playlist');
        if (pl) pl.hidden = !pl.hidden;
      });

      // Feature buttons — dispatch custom events for modules to handle
      function onFeature(id, action) {
        var btn = document.getElementById(id);
        if (btn) btn.addEventListener('click', function(e) {
          e.stopPropagation();
          window.dispatchEvent(new CustomEvent('music-player:' + action, { detail: {} }));
        });
      }
      onFeature('music-btn-library', 'toggle-library');

      // Close buttons for overlays
      function bindClose(id, action) {
        var btn = document.getElementById(id);
        if (btn) btn.addEventListener('click', function(e) {
          e.stopPropagation();
          window.dispatchEvent(new CustomEvent('music-player:' + action, { detail: {} }));
        });
      }
      bindClose('music-lib-close', 'close-library');

      // Playlist item click
      playlistEl.addEventListener('click', function(e) {
        var item = e.target.closest('.music-playlist-item');
        if (item) player.playIndex(parseInt(item.dataset.index));
      });

      // Volume button
      document.getElementById('music-btn-volume').addEventListener('click', function() {
        player.toggleMute();
      });

      // Volume slider
      volumeSlider.addEventListener('mousedown', function(e) {
        e.preventDefault();
        volumeSlider._volDragging = true;
        volumeSlider.classList.add('dragging');
        var rect = volumeSlider.getBoundingClientRect();
        var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        if (volumeFill) volumeFill.style.width = (pct * 100) + '%';
        player.setVolume(pct);
        function onMove(ev) {
          if (!volumeSlider._volDragging) return;
          var r = volumeSlider.getBoundingClientRect();
          var p = Math.max(0, Math.min(1, (ev.clientX - r.left) / r.width));
          if (volumeFill) volumeFill.style.width = (p * 100) + '%';
          player.setVolume(p);
        }
        function onUp() {
          volumeSlider._volDragging = false;
          volumeSlider.classList.remove('dragging');
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
      volumeSlider.addEventListener('touchstart', function(e) {
        e.preventDefault();
        volumeSlider._volDragging = true;
        volumeSlider.classList.add('dragging');
        var rect = volumeSlider.getBoundingClientRect();
        var pct = Math.max(0, Math.min(1, (e.touches[0].clientX - rect.left) / rect.width));
        if (volumeFill) volumeFill.style.width = (pct * 100) + '%';
        player.setVolume(pct);
        function onTouchMove(ev) {
          if (!volumeSlider._volDragging) return;
          var r = volumeSlider.getBoundingClientRect();
          var p = Math.max(0, Math.min(1, (ev.touches[0].clientX - r.left) / r.width));
          if (volumeFill) volumeFill.style.width = (p * 100) + '%';
          player.setVolume(p);
        }
        function onTouchEnd() {
          volumeSlider._volDragging = false;
          volumeSlider.classList.remove('dragging');
          document.removeEventListener('touchmove', onTouchMove);
          document.removeEventListener('touchend', onTouchEnd);
        }
        document.addEventListener('touchmove', onTouchMove);
        document.addEventListener('touchend', onTouchEnd);
      }, { passive: false });

      // Progress bar: drag to seek + hover tooltip
      (function setupProgressDrag() {
        var dragging = false;
        function seekFromEvent(e) {
          var rect = progressBar.getBoundingClientRect();
          var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          if (progressThumb) progressThumb.style.left = (pct * 100) + '%';
          if (progressFill) progressFill.style.width = (pct * 100) + '%';
          if (progressTooltip) {
            progressTooltip.textContent = formatTime(pct * player.getState().duration);
            progressTooltip.style.left = (pct * 100) + '%';
          }
          player.seek(pct * player.getState().duration);
        }
        function showTooltip(e) {
          if (!progressTooltip) return;
          var rect = progressBar.getBoundingClientRect();
          var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          progressTooltip.textContent = formatTime(pct * player.getState().duration);
          progressTooltip.style.left = (pct * 100) + '%';
          progressTooltip.hidden = false;
        }
        function hideTooltip() {
          if (!dragging && progressTooltip) progressTooltip.hidden = true;
        }
        function onMouseDown(e) {
          e.preventDefault();
          dragging = true;
          progressBar.classList.add('dragging');
          if (progressTooltip) progressTooltip.hidden = false;
          seekFromEvent(e);
        }
        function onMouseMove(e) {
          if (dragging) seekFromEvent(e);
          else if (progressBar.matches(':hover')) showTooltip(e);
        }
        function onMouseUp() {
          if (dragging) { dragging = false; progressBar.classList.remove('dragging'); hideTooltip(); }
        }
        function onTouchStart(e) {
          e.preventDefault();
          dragging = true;
          progressBar.classList.add('dragging');
          if (progressTooltip) progressTooltip.hidden = false;
          seekFromEvent(e.touches[0]);
        }
        function onTouchMove(e) {
          if (dragging) seekFromEvent(e.touches[0]);
        }
        function onTouchEnd() {
          if (dragging) { dragging = false; progressBar.classList.remove('dragging'); hideTooltip(); }
        }
        function onMouseEnter(e) { showTooltip(e); }
        function onMouseLeave() { hideTooltip(); }

        progressBar.addEventListener('mousedown', onMouseDown);
        document.addEventListener('mousemove', onMouseMove);
        document.addEventListener('mouseup', onMouseUp);
        progressBar.addEventListener('touchstart', onTouchStart, { passive: false });
        document.addEventListener('touchmove', onTouchMove);
        document.addEventListener('touchend', onTouchEnd);
        progressBar.addEventListener('mouseenter', onMouseEnter);
        progressBar.addEventListener('mouseleave', onMouseLeave);
        _ui._cleanupFns.push(function() {
          progressBar.removeEventListener('mousedown', onMouseDown);
          document.removeEventListener('mousemove', onMouseMove);
          document.removeEventListener('mouseup', onMouseUp);
          progressBar.removeEventListener('touchstart', onTouchStart);
          document.removeEventListener('touchmove', onTouchMove);
          document.removeEventListener('touchend', onTouchEnd);
          progressBar.removeEventListener('mouseenter', onMouseEnter);
          progressBar.removeEventListener('mouseleave', onMouseLeave);
        });
      })();

      // Spectrum visualization on panel canvas
      (function setupSpectrum() {
        if (!spectrumCanvas) return;
        var ctx = spectrumCanvas.getContext('2d');
        var animId = null;
        var freqData = null;
        function resize() {
          var dpr = window.devicePixelRatio || 1;
          var w = spectrumCanvas.clientWidth;
          var h = spectrumCanvas.clientHeight;
          if (spectrumCanvas.width !== w * dpr || spectrumCanvas.height !== h * dpr) {
            spectrumCanvas.width = w * dpr;
            spectrumCanvas.height = h * dpr;
          }
        }
        function draw() {
          animId = requestAnimationFrame(draw);
          var a = player.getAnalyserNode();
          if (!a) return;
          if (!freqData) freqData = new Uint8Array(a.frequencyBinCount);
          resize();
          a.getByteFrequencyData(freqData);
          var w = spectrumCanvas.width;
          var h = spectrumCanvas.height;
          ctx.clearRect(0, 0, w, h);
          var bars = 48;
          var barW = (w / bars) * 0.65;
          var gap = (w / bars) * 0.35;
          var step = Math.floor(freqData.length / bars);
          var hue = getComputedStyle(document.documentElement).getPropertyValue('--hue').trim() || '220';
          for (var i = 0; i < bars; i++) {
            var max = 0;
            for (var j = 0; j < step; j++) max = Math.max(max, freqData[i * step + j]);
            var bh = (max / 255) * h * 0.9;
            var x = i * (barW + gap);
            ctx.fillStyle = 'hsla(' + hue + ', 60%, ' + (48 + (max / 255) * 18) + '%, 0.55)';
            if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(x, h - bh, barW, bh, [barW/2, barW/2, 0, 0]); ctx.fill(); }
            else ctx.fillRect(x, h - bh, barW, bh);
          }
        }
        function start() { if (!animId) draw(); }
        function stop() { if (animId) { cancelAnimationFrame(animId); animId = null; } }
        var specUnsub = player.subscribe(function(s) {
          if (s.isPlaying) start(); else stop();
        });
        _ui._cleanupFns.push(function() { specUnsub(); stop(); });
      })();

      // Error close
      errorClose.addEventListener('click', function() { player.hideError(); });

      // Refresh library button — triggers re-scan (dev) + playlist refresh
      var refreshBtn = document.getElementById('music-lib-refresh');
      var refreshTimeout = null;
      if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
          if (refreshBtn.classList.contains('scanning')) return;
          refreshBtn.classList.add('scanning');
          player.scanAndRefresh().then(function(result) {
            refreshBtn.classList.remove('scanning');
            if (result.success) {
              if (result.added > 0) {
                refreshBtn.title = '已添加 ' + result.added + ' 首新曲目';
              } else {
                refreshBtn.title = '音乐库已是最新';
              }
            } else {
              refreshBtn.title = '刷新失败: ' + (result.error || '未知错误');
            }
            clearTimeout(refreshTimeout);
            refreshTimeout = setTimeout(function() {
              refreshBtn.title = '刷新音乐库';
            }, 3000);
          });
        });
      }

      // Close on outside click
      function onOutsideClick(e) {
        if (expanded && !panel.contains(e.target) && e.target !== fab && !fab.contains(e.target)) {
          closePanel();
        }
      }
      document.addEventListener('click', onOutsideClick);
      _ui._cleanupFns.push(function() {
        document.removeEventListener('click', onOutsideClick);
      });

      // Subscribe
      unsub = player.subscribe(updateUI);
      _ui._cleanupFns.push(function() { if (unsub) { unsub(); unsub = null; } });
      updateUI(player.getState());

      // DSP preset keyboard shortcut: Ctrl+Shift+D cycles through presets
      var dspPresetKeys = ['off', 'classical', 'rock', 'jazz', 'headphones', 'voice'];
      var dspPresetIdx = 0;
      function onDspKeydown(e) {
        if (e.ctrlKey && e.shiftKey && e.key === 'D') {
          e.preventDefault();
          dspPresetIdx = (dspPresetIdx + 1) % dspPresetKeys.length;
          var presetName = dspPresetKeys[dspPresetIdx];
          if (window.__musicPlayer && window.__musicPlayer._decoder) {
            window.__musicPlayer._decoder.applyDspPreset(presetName);
            var preset = window.__musicPlayer._decoder.DSP_PRESETS[presetName];
            console.log('[DSP] Preset: ' + preset.name + ' — ' + preset.description);
          }
        }
      }
      document.addEventListener('keydown', onDspKeydown);
      _ui._cleanupFns.push(function() {
        document.removeEventListener('keydown', onDspKeydown);
      });

      // =================================================================
      // Immersive full-screen playback (Roon-inspired)
      // =================================================================
      setupImmersivePlayback(player);
    }

    var _immCleanupFns = [];
    function setupImmersivePlayback(player) {
      // Clean up previous immersive bindings
      while (_immCleanupFns.length) { _immCleanupFns.pop()(); }
      var immOverlay = document.getElementById('music-immersive-overlay');
      if (!immOverlay) return; // immersive overlay not rendered

      var immBgFront = document.getElementById('music-immersive-bg-front');
      var immBgBack = document.getElementById('music-immersive-bg-back');
      var immArtwork = document.getElementById('music-immersive-artwork');
      var immArtworkImg = immArtwork ? immArtwork.querySelector('img') : null;
      var immTitle = document.getElementById('music-immersive-title');
      var immArtist = document.getElementById('music-immersive-artist');
      var immAlbum = document.getElementById('music-immersive-album');
      var immQuality = document.getElementById('music-immersive-quality');
      var immProgressFill = document.getElementById('music-immersive-progress-fill');
      var immProgressThumb = document.getElementById('music-immersive-progress-thumb');
      var immProgressTooltip = document.getElementById('music-immersive-progress-tooltip');
      var immSpectrum = document.getElementById('music-immersive-spectrum');
      var immCurrent = document.getElementById('music-immersive-current');
      var immDuration = document.getElementById('music-immersive-duration');
      var immIconPlay = document.getElementById('music-immersive-icon-play');
      var immIconPause = document.getElementById('music-immersive-icon-pause');
      var immOpen = false;
      var _lastBgUrl = '';

      function crossfadeBg(url) {
        if (!immBgFront || !immBgBack) return;
        if (url === _lastBgUrl) return;
        _lastBgUrl = url;
        if (!url) {
          immBgFront.style.backgroundImage = '';
          immBgBack.style.backgroundImage = '';
          return;
        }
        // Swap front → back, set new front
        immBgBack.style.backgroundImage = immBgFront.style.backgroundImage;
        immBgBack.style.opacity = '1';
        immBgFront.style.backgroundImage = 'url(' + url + ')';
        immBgFront.style.opacity = '0';
        // Force reflow then crossfade
        immBgFront.offsetHeight;
        immBgFront.style.opacity = '1';
        immBgBack.style.opacity = '0';
      }

      function openImmersive() {
        immOpen = true;
        immOverlay.style.display = '';
        immOverlay.classList.add('open');
        var s = player.getState();
        updateImmersiveUI(s);

        // Fade in artwork
        if (immArtwork) {
          immArtwork.classList.remove('fade-out');
        }
      }

      function closeImmersive() {
        immOpen = false;
        immOverlay.classList.remove('open');
        setTimeout(function() {
          if (!immOpen && immOverlay) immOverlay.style.display = 'none';
        }, 650);
      }

      function toggleImmersive() {
        immOpen ? closeImmersive() : openImmersive();
      }

      function updateImmersiveUI(s) {
        // Background crossfade
        if (s.currentSong && s.currentSong.cover) {
          crossfadeBg(s.currentSong.cover);
        }

        // Artwork
        if (immArtworkImg && s.currentSong && s.currentSong.cover) {
          immArtworkImg.src = s.currentSong.cover;
        }

        // Track info
        if (immTitle) immTitle.textContent = s.currentSong.title || '--';
        if (immArtist) immArtist.textContent = s.currentSong.artist || '--';
        if (immAlbum) immAlbum.textContent = s.currentSong.album ? (s.currentSong.album + (s.currentSong.year ? ' · ' + s.currentSong.year : '')) : '';
        if (immQuality) {
          if (s.currentSong.qualityLabel) {
            immQuality.textContent = s.currentSong.qualityLabel;
            immQuality.style.display = 'inline-flex';
          } else {
            immQuality.style.display = 'none';
          }
        }

        // Progress
        if (immProgressFill) {
          var ipct = s.duration > 0 ? (s.currentTime / s.duration) * 100 : 0;
          immProgressFill.style.width = ipct + '%';
          if (immProgressThumb) immProgressThumb.style.left = ipct + '%';
        }
        if (immCurrent) immCurrent.textContent = formatTime(s.currentTime);
        if (immDuration) immDuration.textContent = formatTime(s.duration);

        // Play/pause
        if (immIconPlay) immIconPlay.hidden = s.isPlaying;
        if (immIconPause) immIconPause.hidden = !s.isPlaying;

        // Shuffle / repeat state
        var immShuffle = document.getElementById('music-immersive-shuffle');
        var immRepeat = document.getElementById('music-immersive-repeat');
        if (immShuffle) immShuffle.classList.toggle('active', s.isShuffled);
        if (immRepeat) immRepeat.classList.toggle('active', s.isRepeating !== 0);
      }

      // Button bindings
      var immPlayBtn = document.getElementById('music-immersive-play');
      var immPrevBtn = document.getElementById('music-immersive-prev');
      var immNextBtn = document.getElementById('music-immersive-next');
      var immShuffleBtn = document.getElementById('music-immersive-shuffle');
      var immRepeatBtn = document.getElementById('music-immersive-repeat');
      var immCloseBtn = document.getElementById('music-immersive-close');
      var immProgressBar = document.getElementById('music-immersive-progress-bar');

      if (immPlayBtn) immPlayBtn.addEventListener('click', function() { player.toggle(); });
      if (immPrevBtn) immPrevBtn.addEventListener('click', function() { player.prev(); });
      if (immNextBtn) immNextBtn.addEventListener('click', function() { player.next(); });
      if (immShuffleBtn) immShuffleBtn.addEventListener('click', function() { player.toggleShuffle(); });
      if (immRepeatBtn) immRepeatBtn.addEventListener('click', function() {
        player.toggleRepeat();
        var s = player.getState();
        immRepeatBtn.classList.toggle('active', s.isRepeating !== 0);
      });
      if (immCloseBtn) immCloseBtn.addEventListener('click', closeImmersive);

      // Immersive progress bar: drag to seek + tooltip
      if (immProgressBar) {
        (function() {
          var dragging = false;
          function seekFromEvent(e) {
            var rect = immProgressBar.getBoundingClientRect();
            var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            if (immProgressFill) immProgressFill.style.width = (pct * 100) + '%';
            if (immProgressThumb) immProgressThumb.style.left = (pct * 100) + '%';
            if (immProgressTooltip) {
              immProgressTooltip.textContent = formatTime(pct * player.getState().duration);
              immProgressTooltip.style.left = (pct * 100) + '%';
            }
            player.seek(pct * player.getState().duration);
          }
          function showTooltip(e) {
            if (!immProgressTooltip) return;
            var rect = immProgressBar.getBoundingClientRect();
            var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            immProgressTooltip.textContent = formatTime(pct * player.getState().duration);
            immProgressTooltip.style.left = (pct * 100) + '%';
            immProgressTooltip.hidden = false;
          }
          function hideTooltip() {
            if (!dragging && immProgressTooltip) immProgressTooltip.hidden = true;
          }
          immProgressBar.addEventListener('mousedown', function(e) {
            e.preventDefault();
            dragging = true;
            immProgressBar.classList.add('dragging');
            if (immProgressTooltip) immProgressTooltip.hidden = false;
            seekFromEvent(e);
          });
          document.addEventListener('mousemove', function(e) {
            if (dragging) seekFromEvent(e);
            else if (immProgressBar.matches(':hover')) showTooltip(e);
          });
          document.addEventListener('mouseup', function() {
            if (dragging) { dragging = false; immProgressBar.classList.remove('dragging'); hideTooltip(); }
          });
          immProgressBar.addEventListener('touchstart', function(e) {
            e.preventDefault();
            dragging = true;
            immProgressBar.classList.add('dragging');
            if (immProgressTooltip) immProgressTooltip.hidden = false;
            seekFromEvent(e.touches[0]);
          }, { passive: false });
          document.addEventListener('touchmove', function(e) {
            if (dragging) seekFromEvent(e.touches[0]);
          });
          document.addEventListener('touchend', function() {
            if (dragging) { dragging = false; immProgressBar.classList.remove('dragging'); hideTooltip(); }
          });
          immProgressBar.addEventListener('mouseenter', function(e) { showTooltip(e); });
          immProgressBar.addEventListener('mouseleave', function() { hideTooltip(); });
        })();
      }

      // Immersive spectrum visualization
      if (immSpectrum) {
        (function() {
          var ctx = immSpectrum.getContext('2d');
          var animId = null;
          var freqData = null;
          function resize() {
            var dpr = window.devicePixelRatio || 1;
            var w = immSpectrum.clientWidth;
            var h = immSpectrum.clientHeight;
            if (immSpectrum.width !== w * dpr || immSpectrum.height !== h * dpr) {
              immSpectrum.width = w * dpr;
              immSpectrum.height = h * dpr;
            }
          }
          function draw() {
            animId = requestAnimationFrame(draw);
            var a = player.getAnalyserNode();
            if (!a) return;
            if (!freqData) freqData = new Uint8Array(a.frequencyBinCount);
            resize();
            a.getByteFrequencyData(freqData);
            var w = immSpectrum.width;
            var h = immSpectrum.height;
            ctx.clearRect(0, 0, w, h);
            var bars = 64;
            var barW = (w / bars) * 0.6;
            var gap = (w / bars) * 0.4;
            var step = Math.floor(freqData.length / bars);
            for (var i = 0; i < bars; i++) {
              var max = 0;
              for (var j = 0; j < step; j++) max = Math.max(max, freqData[i * step + j]);
              var bh = (max / 255) * h * 0.85;
              var x = i * (barW + gap);
              ctx.fillStyle = 'rgba(255,255,255,' + (0.2 + (max / 255) * 0.35) + ')';
              if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(x, h - bh, barW, bh, [barW/2, barW/2, 0, 0]); ctx.fill(); }
              else ctx.fillRect(x, h - bh, barW, bh);
            }
          }
          function start() { if (!animId) draw(); }
          function stop() { if (animId) { cancelAnimationFrame(animId); animId = null; } }
          var immSpecUnsub = player.subscribe(function(s) {
            if (s.isPlaying && immOpen) start(); else stop();
          });
          _immCleanupFns.push(function() { immSpecUnsub(); stop(); });
        })();
      }

      // Keyboard: Escape to close
      function onKeydown(e) {
        if (e.key === 'Escape' && immOpen) {
          closeImmersive();
        }
      }
      document.addEventListener('keydown', onKeydown);
      _immCleanupFns.push(function() { document.removeEventListener('keydown', onKeydown); });

      // Subscribe to state updates while open
      var immUnsub = player.subscribe(function(s) {
        if (immOpen) updateImmersiveUI(s);
      });
      _immCleanupFns.push(immUnsub);

      // Expose on player
      window.__musicPlayer._immersive = {
        open: openImmersive,
        close: closeImmersive,
        toggle: toggleImmersive,
        isOpen: function() { return immOpen; },
      };

      // Listen for external events
      window.addEventListener('music-player:open-immersive', openImmersive);
      window.addEventListener('music-player:close-immersive', closeImmersive);
      window.addEventListener('music-player:toggle-immersive', toggleImmersive);
      _immCleanupFns.push(function() {
        window.removeEventListener('music-player:open-immersive', openImmersive);
        window.removeEventListener('music-player:close-immersive', closeImmersive);
        window.removeEventListener('music-player:toggle-immersive', toggleImmersive);
      });
    }

    // Wait for music player engine (loaded with defer)
    function boot() {
      var player = window.__musicPlayer;
      if (player) {
        setup(player);
      } else {
        setTimeout(boot, 20);
      }
    }
    boot();

    // Cleanup on navigation — clean all listeners
    document.addEventListener('astro:before-swap', function() {
      if (unsub) { unsub(); unsub = null; }
      while (_ui._cleanupFns.length) { _ui._cleanupFns.pop()(); }
      while (_immCleanupFns.length) { _immCleanupFns.pop()(); }
    });

    // Re-setup after Astro page swap (DOM elements are fresh)
    document.addEventListener('astro:after-swap', function() {
      // Cleanup previous
      if (unsub) { unsub(); unsub = null; }
      while (_ui._cleanupFns.length) { _ui._cleanupFns.pop()(); }
      while (_immCleanupFns.length) { _immCleanupFns.pop()(); }
      // Re-bind DOM refs
      fab = document.getElementById('music-fab');
      if (!fab) return;
      panel = document.getElementById('music-panel');
      cover = document.getElementById('music-cover');
      titleEl = document.getElementById('music-title');
      artistEl = document.getElementById('music-artist');
      progressBar = document.getElementById('music-progress-bar');
      progressFill = document.getElementById('music-progress-fill');
      progressThumb = document.getElementById('music-progress-thumb');
      progressTooltip = document.getElementById('music-progress-tooltip');
      spectrumCanvas = document.getElementById('music-spectrum-canvas');
      currentTimeEl = document.getElementById('music-current-time');
      durationEl = document.getElementById('music-duration');
      volumeSlider = document.getElementById('music-volume-slider');
      volumeFill = document.getElementById('music-volume-fill');
      playlistEl = document.getElementById('music-playlist');
      errorEl = document.getElementById('music-error');
      errorMsg = document.getElementById('music-error-msg');
      errorClose = document.getElementById('music-error-close');
      fabDot = document.getElementById('music-fab-dot');
      iconPlay = document.getElementById('music-icon-play');
      iconPause = document.getElementById('music-icon-pause');
      iconVolume = document.getElementById('music-icon-volume');
      iconMute = document.getElementById('music-icon-mute');
      repeatOne = document.getElementById('music-repeat-one');
      decoderBadge = document.getElementById('music-decoder-badge');
      decoderCodec = document.getElementById('music-decoder-codec');
      dspIndicator = document.getElementById('music-panel-dsp');
      dspPath = document.getElementById('music-dsp-path');
      expanded = false;

      function rebind() {
        var player = window.__musicPlayer;
        if (player) {
          setup(player);
          // setup() already calls setupImmersivePlayback internally
        } else {
          setTimeout(rebind, 20);
        }
      }
      rebind();
    });
  })();
</script>
