---
import { siteConfig } from "../config";
import { getStrings } from "../i18n";

const ui = await getStrings(siteConfig.lang);
---

<button class="settings-fab" id="settings-fab" title="设置" aria-label="设置">
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="3"></circle>
    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
  </svg>
</button>

<div class="settings-panel float-panel float-panel-closed" id="settings-panel">
  <div class="settings-header">
    <span>{ui["settings.title"]}</span>
    <button class="settings-close" id="settings-close" aria-label="关闭">&times;</button>
  </div>
  <div class="settings-body">
    <!-- Theme hue slider -->
    <div>
      <div class="settings-section-title">{ui["settings.themeHue"]}</div>
      <input type="range" class="settings-hue-slider" id="hue-slider" min="0" max="360" value="250" />
    </div>

    <!-- Wallpaper mode -->
    <div>
      <div class="settings-section-title">{ui["settings.wallpaperMode"]}</div>
      <div class="settings-row" style="gap:6px">
        <button class="settings-mode-btn active" data-mode="banner">{ui["settings.modeBanner"]}</button>
        <button class="settings-mode-btn" data-mode="fullscreen">{ui["settings.modeFullscreen"]}</button>
        <button class="settings-mode-btn" data-mode="overlay">{ui["settings.modeOverlay"]}</button>
        <button class="settings-mode-btn" data-mode="none">{ui["settings.modeNone"]}</button>
      </div>
    </div>

    <!-- Wallpaper overlay sliders (shown only in overlay mode) -->
    <div id="overlay-settings" style="display:none">
      <div class="settings-section-title">{ui["settings.overlayEffects"]}</div>
      <div class="settings-range-row">
        <span class="settings-label" style="font-size:0.75rem;min-width:36px">{ui["settings.opacity"]}</span>
        <input type="range" id="overlay-opacity" min="20" max="100" value="80" />
        <span class="settings-range-value" id="overlay-opacity-val">80%</span>
      </div>
      <div class="settings-range-row">
        <span class="settings-label" style="font-size:0.75rem;min-width:36px">{ui["settings.blur"]}</span>
        <input type="range" id="overlay-blur" min="0" max="12" value="1.5" step="0.5" />
        <span class="settings-range-value" id="overlay-blur-val">1.5px</span>
      </div>
      <div class="settings-range-row">
        <span class="settings-label" style="font-size:0.75rem;min-width:36px">{ui["settings.cardOpacity"]}</span>
        <input type="range" id="overlay-card-opacity" min="20" max="100" value="80" />
        <span class="settings-range-value" id="overlay-card-opacity-val">80%</span>
      </div>
    </div>

    <!-- Sakura toggle -->
    <div>
      <div class="settings-row">
        <span class="settings-label">{ui["settings.sakura"]}</span>
        <button class="settings-toggle" id="sakura-toggle" aria-label="切换樱花效果"></button>
      </div>
    </div>
  </div>
</div>

<!-- Event handling centralized in CoreManager.astro (head) — Mizuki event delegation pattern -->
