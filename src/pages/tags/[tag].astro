---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tags.add(tag);
    }
  }
  return Array.from(tags).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const allPosts = await getCollection("posts", ({ data }) => {
  if (import.meta.env.PROD && data.draft) return false;
  return data.tags.includes(tag!);
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);
---

<Layout title={`标签: ${tag}`}>
  <div class="mx-auto max-w-4xl">
    <!-- Page header -->
    <header class="mb-10">
      <h1 class="text-2xl font-bold">
        标签: <span class="text-[var(--color-primary)]">{tag}</span>
      </h1>
      <p class="mt-1 text-sm text-[var(--color-text-secondary)]">
        共 {sortedPosts.length} 篇文章
      </p>
      <div class="page-header-divider"></div>
    </header>

    {
      sortedPosts.length === 0 && (
        <div class="py-20 text-center text-[var(--color-text-secondary)]">
          <p class="text-lg">该标签下暂无文章</p>
          <a
            href="/tags/"
            class="mt-4 inline-block text-sm text-[var(--color-primary)] hover:underline"
          >
            浏览所有标签 →
          </a>
        </div>
      )
    }

    <div class="post-grid">
      {sortedPosts.map((post) => <PostCard post={post} />)}
    </div>

    <div class="mt-10">
      <a href="/tags/" class="btn-regular rounded-lg px-4 py-2 text-sm"> &larr; 所有标签 </a>
    </div>
  </div>
</Layout>
