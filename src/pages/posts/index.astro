---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { POSTS_PER_PAGE, siteConfig } from "../../config";
import { getReadingStats } from "../../utils/reading-time";

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const sortedPosts = allPosts.sort((a, b) => {
  if (a.data.pinned && !b.data.pinned) return -1;
  if (!a.data.pinned && b.data.pinned) return 1;
  return b.data.published.valueOf() - a.data.published.valueOf();
});

// Collect all tags from all posts
const allTags = new Map<string, number>();
sortedPosts.forEach((p) => {
  p.data.tags.forEach((t) => allTags.set(t, (allTags.get(t) || 0) + 1));
});
const topTags = [...allTags.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const currentPage = 1;
const totalPages = Math.ceil(sortedPosts.length / POSTS_PER_PAGE);
const pagePosts = sortedPosts.slice(0, POSTS_PER_PAGE);

// Calculate total word count
let totalChars = 0;
sortedPosts.forEach((p) => {
  if (p.body) totalChars += getReadingStats(p.body).chars;
});
---

<Layout
  title="文章"
  description={siteConfig.subtitle}
>
  <div class="mx-auto max-w-4xl">
    <!-- Page header -->
    <header class="mb-10">
      <div class="flex items-end justify-between">
        <div>
          <h1 class="text-2xl font-bold">文章</h1>
          <p class="mt-1 text-sm text-[var(--color-text-secondary)]">
            共 {sortedPosts.length} 篇文章
          </p>
        </div>
        <div class="hidden sm:flex items-center gap-4 text-xs text-[var(--color-text-muted)]">
          <span>{allTags.size} 个标签</span>
        </div>
      </div>
      <div class="page-header-divider"></div>
    </header>

    <!-- Stats row -->
    <div class="stats-grid mb-10">
      <div class="stat-card">
        <span class="stat-number">{sortedPosts.length}</span>
        <span class="stat-label">文章总数</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{allTags.size}</span>
        <span class="stat-label">标签分类</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{totalChars > 10000 ? Math.round(totalChars / 1000) + 'k' : totalChars.toLocaleString()}</span>
        <span class="stat-label">总字数</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{currentPage}/{totalPages || 1}</span>
        <span class="stat-label">当前页码</span>
      </div>
    </div>

    <!-- Tag cloud (quick filter) -->
    {topTags.length > 0 && (
      <div class="mb-8 flex flex-wrap items-center gap-2">
        <span class="text-xs font-medium text-[var(--color-text-muted)] mr-1">热门标签:</span>
        {topTags.map(([tag, count]) => (
          <a href={`/tags/${tag}/`} class="tag-chip">
            {tag} <span class="ml-1 opacity-60">{count}</span>
          </a>
        ))}
        <a href="/tags/" class="text-xs text-[var(--color-primary)] hover:underline ml-1">
          查看全部 →
        </a>
      </div>
    )}

    <!-- Empty state -->
    {pagePosts.length === 0 && (
      <div class="py-20 text-center text-[var(--color-text-secondary)]">
        <svg class="mx-auto mb-4 h-12 w-12 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        <p class="text-lg">还没有文章</p>
        <p class="mt-2 text-sm">开始写你的第一篇博客吧</p>
      </div>
    )}

    <!-- Post grid -->
    <div class="post-grid">
      {pagePosts.map((post) => <PostCard post={post} />)}
    </div>

    <!-- Pagination -->
    <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/posts/" />

    <!-- Footer note -->
    <div class="mt-12 text-center">
      <div class="doc-footer">
        <p>
          互联网是有记忆的，我想留下一些成长的脚印。 — <a href="/" class="text-[var(--color-primary)] no-underline hover:underline">Soren的知识库</a>
        </p>
      </div>
    </div>
  </div>
</Layout>
