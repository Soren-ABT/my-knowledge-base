---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import JsonLd from "../../components/JsonLd.astro";
import { formatDateFull, formatDate } from "../../utils/date";
import { getReadingStats } from "../../utils/reading-time";
import { licenseConfig, profileConfig, siteConfig } from "../../config";
import { normalizeSlug } from "../../utils/slug";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });
  return posts.map((post) => {
    const slug = normalizeSlug(post.id);
    return { params: { slug } };
  });
}

const { slug } = Astro.params;
const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Sort for prev/next navigation
const sorted = allPosts.sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);

const currentIndex = sorted.findIndex((p) => {
  const s = normalizeSlug(p.id);
  return s === slug;
});

const post = sorted[currentIndex];
if (!post) {
  return Astro.redirect("/404/");
}

const prevPost = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const { data } = post;
const { Content, headings } = await render(post);
const postSlug = normalizeSlug(post.id);

function prevSlug(p: CollectionEntry<"posts">) {
  return normalizeSlug(p.id);
}

// Calculate reading time
const readingStats = post.body ? getReadingStats(post.body) : { chars: 0, minutes: 1 };
const wordCount = readingStats.chars;
	const readingTime = readingStats.minutes;
---

<Layout
  title={data.title}
  description={data.description}
  ogImage={data.image || (siteConfig.generateOgImages ? `/og/${postSlug}.png` : undefined)}
>
  <!-- Structured data for SEO -->
  <JsonLd
    data={{
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: data.title,
      description: data.description,
      image: data.image || undefined,
      datePublished: data.published.toISOString(),
      dateModified: data.updated ? data.updated.toISOString() : data.published.toISOString(),
      author: {
        "@type": "Person",
        name: profileConfig.name,
      },
      url: new URL(`/posts/${postSlug}/`, Astro.site).toString(),
      publisher: {
        "@type": "Person",
        name: profileConfig.name,
      },
    }}
  />

  <article class="mx-auto max-w-4xl">
    <!-- Header with cover-style design -->
    <header class="mb-10">
      <!-- Tags -->
      {data.tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {data.tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="tag-link">{tag}</a>
          ))}
        </div>
      )}

      <!-- Title -->
      <h1 class="mb-4 text-2xl font-extrabold leading-tight sm:text-3xl md:text-4xl">
        {data.title}
      </h1>

      <!-- Description -->
      {data.description && (
        <p class="mb-5 text-base leading-relaxed text-[var(--color-text-secondary)] sm:text-lg">
          {data.description}
        </p>
      )}

      <!-- Meta bar -->
      <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-text-muted)]">
        <time datetime={data.published.toISOString()}>
          发布于 {formatDateFull(data.published)}
        </time>
        {data.updated && (
          <time datetime={data.updated.toISOString()}>
            · 更新于 {formatDateFull(data.updated)}
          </time>
        )}
        {data.category && (
          <span>· <a href={`/tags/${data.category}/`} class="text-[var(--color-primary)] no-underline hover:underline">{data.category}</a></span>
        )}
        <span class="hidden sm:inline">· {wordCount > 1000 ? Math.round(wordCount / 1000) + 'k' : wordCount} 字</span>
        <span class="hidden sm:inline">· 约 {readingTime} 分钟</span>
      </div>

      <div class="page-header-divider"></div>
    </header>

    <!-- Cover image (if available) -->
    {data.image && (
      <div class="banner-container mb-10 overflow-hidden rounded-xl border border-[var(--color-border)]">
        <img
          src={data.image}
          alt={data.title}
          class="w-full object-cover max-h-[420px]"
          loading="eager"
        />
      </div>
    )}

    <div class="lg:flex lg:gap-10">
      <!-- Main content -->
      <div class="min-w-0 flex-1">
        <div class="content-glass animate-content">
          <div class="prose max-w-none markdown-section">
            <Content />
          </div>
        </div>

        <!-- License -->
        {licenseConfig.enable && (
          <div class="mt-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 text-sm leading-relaxed text-[var(--color-text-secondary)]">
            <div class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 shrink-0 text-[var(--color-primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              <div>
                <p class="mb-1 font-medium text-[var(--color-text)]">版权声明</p>
                <p>
                  本文采用
                  <a
                    href={licenseConfig.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[var(--color-primary)] font-medium hover:underline"
                  >
                    {licenseConfig.name}
                  </a>
                  许可协议。转载请注明出处。
                </p>
              </div>
            </div>
          </div>
        )}

        <!-- Tags at bottom -->
        {data.tags.length > 0 && (
          <div class="mt-8 flex flex-wrap items-center gap-2">
            <span class="text-xs text-[var(--color-text-muted)]">标签:</span>
            {data.tags.map((tag) => (
              <a href={`/tags/${tag}/`} class="tag-chip">{tag}</a>
            ))}
          </div>
        )}

        <!-- Prev / Next navigation -->
        <nav class="mt-8 grid gap-4 sm:grid-cols-2">
          {prevPost && (
            <a
              href={`/posts/${prevSlug(prevPost)}/`}
              class="card-base group flex flex-col rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5 no-underline transition-all"
            >
              <span class="text-xs text-[var(--color-text-muted)]">← 上一篇</span>
              <span class="mt-1.5 text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors line-clamp-1">
                {prevPost.data.title}
              </span>
              {prevPost.data.description && (
                <span class="mt-1 text-xs text-[var(--color-text-muted)] line-clamp-1">
                  {prevPost.data.description}
                </span>
              )}
            </a>
          )}
          {nextPost && (
            <a
              href={`/posts/${prevSlug(nextPost)}/`}
              class="card-base group flex flex-col items-end rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5 no-underline transition-all sm:text-right"
            >
              <span class="text-xs text-[var(--color-text-muted)]">下一篇 →</span>
              <span class="mt-1.5 text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors line-clamp-1">
                {nextPost.data.title}
              </span>
              {nextPost.data.description && (
                <span class="mt-1 text-xs text-[var(--color-text-muted)] line-clamp-1">
                  {nextPost.data.description}
                </span>
              )}
            </a>
          )}
        </nav>
      </div>

      <!-- Sidebar: Table of Contents -->
      <aside class="hidden w-60 shrink-0 lg:block">
        <div id="toc-container" class="sticky top-24">
          <!-- Populated by BlogLayout inline script -->
        </div>

        <!-- Quick stats -->
        <div class="sticky mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-4 top-[calc(24px+var(--toc-height,300px))]">
          <div class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">文章信息</div>
          <div class="space-y-2 text-xs text-[var(--color-text-secondary)]">
            <div class="flex justify-between">
              <span>发布</span>
              <span class="text-[var(--color-text)]">{formatDate(data.published)}</span>
            </div>
            {data.updated && (
              <div class="flex justify-between">
                <span>更新</span>
                <span class="text-[var(--color-text)]">{formatDate(data.updated)}</span>
              </div>
            )}
            <div class="flex justify-between">
              <span>字数</span>
              <span class="text-[var(--color-text)]">{wordCount > 1000 ? Math.round(wordCount / 1000) + 'k' : wordCount}</span>
            </div>
            <div class="flex justify-between">
              <span>阅读</span>
              <span class="text-[var(--color-text)]">~{readingTime} 分钟</span>
            </div>
            {data.category && (
              <div class="flex justify-between">
                <span>分类</span>
                <a href={`/tags/${data.category}/`} class="text-[var(--color-primary)] no-underline hover:underline">{data.category}</a>
              </div>
            )}
          </div>
        </div>
      </aside>
    </div>
  </article>
</Layout>
