---
import Layout from "../layouts/Layout.astro";
import PagefindSearch from "../components/PagefindSearch.astro";
import { siteConfig } from "../config";
import { getStrings } from "../i18n";

const ui = await getStrings(siteConfig.lang);
---

<Layout title={ui["search.title"]} description={ui["search.desc"]}>
  <div class="mx-auto">
    <header class="mb-6">
      <h1 class="text-2xl font-bold">{ui["search.title"]}</h1>
      <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{ui["search.desc"]}</p>
      <div class="page-header-divider"></div>
    </header>
    <PagefindSearch />
  </div>
</Layout>
