---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import PostCard from "../components/PostCard.astro";
import JsonLd from "../components/JsonLd.astro";
import { siteConfig, profileConfig, POSTS_PER_PAGE } from "../config";
import { getStrings, interpolate } from "../i18n";
import { getReadingStats } from "../utils/reading-time";

const ui = await getStrings(siteConfig.lang);

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const sortedPosts = allPosts.sort((a, b) => {
  if (a.data.pinned && !b.data.pinned) return -1;
  if (!a.data.pinned && b.data.pinned) return 1;
  return b.data.published.valueOf() - a.data.published.valueOf();
});

const allTags = new Map<string, number>();
let totalChars = 0;
sortedPosts.forEach((p) => {
  p.data.tags.forEach((t) => allTags.set(t, (allTags.get(t) || 0) + 1));
  if (p.body) totalChars += getReadingStats(p.body).chars;
});

const topTags = [...allTags.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const latestPosts = sortedPosts.slice(0, POSTS_PER_PAGE);
const hasLinks = profileConfig.links.length > 0;
const pinnedCount = sortedPosts.filter(p => p.data.pinned).length;

// Clock data (server-rendered initial values)
const now = new Date();
const clockInitial = {
  time: now.toLocaleTimeString("zh-CN", { hour12: false }),
  date: `${now.getFullYear()}年${now.getMonth() + 1}月${now.getDate()}日`,
  weekday: ["日", "一", "二", "三", "四", "五", "六"][now.getDay()],
};
---

<Layout>
  <JsonLd
    data={{
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "name": siteConfig.title,
          "url": siteConfig.siteURL,
          "description": siteConfig.subtitle,
          "inLanguage": siteConfig.lang,
        },
        {
          "@type": "Person",
          "name": profileConfig.name,
          "url": siteConfig.siteURL,
        },
      ],
    }}
  />
  <div class="home-layout">
    <!-- Hero section -->
    <section class="home-hero">
      <div class="hero-card">
        <div class="hero-top-bar"></div>
        <div class="hero-body">
          <div class="hero-text">
            <h1 class="hero-title">{siteConfig.title}</h1>
            <p class="hero-subtitle">{siteConfig.subtitle}</p>
          </div>
          <div class="hero-stats">
            <div class="hero-stat">
              <svg class="hero-stat-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              <span class="hero-stat-num stat-posts">{sortedPosts.length}</span>
              <span class="hero-stat-label">{ui["home.posts"]}</span>
            </div>
            <div class="hero-stat">
              <svg class="hero-stat-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#a855f7" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              <span class="hero-stat-num stat-tags">{allTags.size}</span>
              <span class="hero-stat-label">{ui["home.tags"]}</span>
            </div>
            <div class="hero-stat">
              <svg class="hero-stat-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              <span class="hero-stat-num stat-words">{totalChars > 10000 ? Math.round(totalChars / 1000) + 'k' : totalChars.toLocaleString()}</span>
              <span class="hero-stat-label">{ui["home.words"]}</span>
            </div>
            <div class="hero-stat">
              <svg class="hero-stat-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="1.8"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2z"/></svg>
              <span class="hero-stat-num stat-pinned">{pinnedCount}</span>
              <span class="hero-stat-label">{ui["home.pinned"]}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Two-column main area -->
    <div class="home-main">
      <!-- Sidebar -->
      <aside class="home-sidebar">
        <!-- Profile -->
        <div class="sidebar-card">
          <div class="sidebar-profile">
            {profileConfig.avatar ? (
              <div class="profile-avatar-wrap">
                <div class="profile-avatar-ring"></div>
                <img src={profileConfig.avatar} alt={profileConfig.name} class="profile-avatar-img" />
              </div>
            ) : (
              <div class="profile-avatar-wrap">
                <div class="profile-avatar-ring"></div>
                <div class="profile-avatar-initial">{profileConfig.name[0]}</div>
              </div>
            )}
            <div class="sidebar-profile-text">
              <p class="sidebar-name">{profileConfig.name}</p>
              {profileConfig.bio && (
                <p class="sidebar-bio">{profileConfig.bio}</p>
              )}
            </div>
          </div>
          <div class="profile-gradient-line"></div>
          {hasLinks && (
            <div class="sidebar-links">
              {profileConfig.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="sidebar-link-item"
                >
                  {link.icon === 'github' && (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                  )}
                  {link.icon === 'email' && (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  )}
                  {link.name}
                </a>
              ))}
            </div>
          )}
        </div>

        <!-- Now Playing (Kirameku CloudPlayer inspired) -->
        <div class="sidebar-card sidebar-nowplaying">
          <p class="sidebar-section-title">{ui["home.nowPlaying"]}</p>
          <!-- Idle state -->
          <div id="np-no-music" class="np-idle">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            <span>{ui["home.noMusic"]}</span>
          </div>
          <!-- Playing state (hidden by default) -->
          <div id="np-body" style="display:none">
            <div class="np-cover-row" id="np-cover-wrap">
              <img id="np-cover" src="" alt="" class="np-cover" />
              <div class="np-cover-overlay">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><rect x="4" y="4" width="16" height="16" rx="2"/></svg>
              </div>
            </div>
            <p id="np-title" class="np-title"></p>
            <p id="np-artist" class="np-artist"></p>
            <!-- Progress -->
            <div class="np-progress-bar">
              <div id="np-progress-fill" class="np-progress-fill"></div>
            </div>
            <p id="np-time" class="np-time">--:-- / --:--</p>
            <!-- Controls -->
            <div class="np-controls">
              <button id="np-prev" class="np-btn" aria-label="上一首">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
              </button>
              <button id="np-play" class="np-btn np-btn-play" data-playing="0" aria-label="播放">
                <svg class="np-icon-play" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                <svg class="np-icon-pause" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
              </button>
              <button id="np-next" class="np-btn" aria-label="下一首">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Live Clock (Kirameku SiteDashboard inspired) -->
        <div class="sidebar-card sidebar-clock">
          <p class="sidebar-section-title">{ui["home.time"]}</p>
          <div class="clock-display">
            <span id="clock-time" class="clock-time">{clockInitial.time}</span>
            <span id="clock-date" class="clock-date">{clockInitial.date} 星期{clockInitial.weekday}</span>
          </div>
        </div>

        <!-- Quick nav -->
        <div class="sidebar-card">
          <div class="sidebar-nav">
            <a href="/posts/" class="sidebar-nav-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              {ui["nav.posts"]}
            </a>
            <a href="/archive/" class="sidebar-nav-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {ui["nav.archive"]}
            </a>
            <a href="/tags/" class="sidebar-nav-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              {ui["nav.tags"]}
            </a>
            <a href="/gallery/" class="sidebar-nav-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
              {ui["nav.gallery"]}
            </a>
            <a href="/docs/" class="sidebar-nav-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              {ui["nav.docs"]}
            </a>
            <a href="/about/" class="sidebar-nav-item">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              {ui["nav.about"]}
            </a>
          </div>
        </div>

        <!-- Tags -->
        {topTags.length > 0 && (
          <div class="sidebar-card">
            <p class="sidebar-section-title">{ui["home.hotTags"]}</p>
            <div class="sidebar-tags">
              {topTags.map(([tag, count]) => (
                <a href={`/tags/${tag}/`} class="tag-chip">
                  {tag} <span class="sidebar-tag-count">{count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </aside>

      <!-- Main content: post list -->
      <section class="home-content">
        <div class="home-posts-header">
          <div>
            <h2 class="home-posts-title">{ui["home.latestPosts"]}</h2>
            <div class="page-header-divider"></div>
          </div>
          <span class="home-posts-count">{interpolate(ui["home.totalPosts"], { count: sortedPosts.length })}</span>
        </div>

        {latestPosts.length === 0 ? (
          <div class="card-base border border-[var(--color-border)] py-16 text-center text-[var(--color-text-secondary)]">
            <svg class="mx-auto mb-4 h-12 w-12 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <p class="text-lg">{ui["home.noPosts"]}</p>
            <p class="mt-2 text-sm">{ui["home.noPostsHint"]}</p>
          </div>
        ) : (
          <div class="home-post-list">
            {latestPosts.map((post) => <PostCard post={post} />)}
          </div>
        )}

        {sortedPosts.length > POSTS_PER_PAGE && (
          <div class="home-posts-footer">
            <a href="/posts/" class="btn-regular">
              {interpolate(ui["home.viewAll"], { count: sortedPosts.length })}
            </a>
          </div>
        )}
      </section>
    </div>
  </div>

  <!-- Now-playing client script -->
  <script defer src="/js/now-playing.js"></script>

  <!-- Live clock -->
  <script defer src="/js/clock.js"></script>
</Layout>
