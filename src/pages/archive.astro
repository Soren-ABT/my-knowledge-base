---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import {
  buildRiverPath,
  totalWidth,
  cardPositions,
  estimatePathLength,
  sparklePositions,
  floatingParticles,
  makeRiverData,
} from "../scripts/archive/river-math";
import type { RiverConfig } from "../scripts/archive/river-math";
import ArchiveViewTabs from "../components/archive/ArchiveViewTabs.astro";
import ArchiveStats from "../components/archive/ArchiveStats.astro";
import ArchiveYearNav from "../components/archive/ArchiveYearNav.astro";
import TimelineView from "../components/archive/TimelineView.astro";
import RiverView from "../components/archive/RiverView.astro";
import "../styles/archive/tabs.css";
import "../styles/archive/timeline.css";
import "../styles/archive/river.css";

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);

// ── View A (Timeline): year → month → posts ─────────────
type MonthGroup = { month: number; posts: typeof sortedPosts };
const groupedByYear = new Map<number, MonthGroup[]>();
for (const post of sortedPosts) {
  const year = post.data.published.getFullYear();
  const month = post.data.published.getMonth();
  if (!groupedByYear.has(year)) groupedByYear.set(year, []);
  const months = groupedByYear.get(year)!;
  let mg = months.find((m) => m.month === month);
  if (!mg) {
    mg = { month, posts: [] };
    months.push(mg);
  }
  mg.posts.push(post);
}
for (const months of groupedByYear.values()) {
  months.sort((a, b) => b.month - a.month);
}

const years = Array.from(groupedByYear.keys()).sort((a, b) => b - a);
const MONTH_NAMES = [
  "1月",
  "2月",
  "3月",
  "4月",
  "5月",
  "6月",
  "7月",
  "8月",
  "9月",
  "10月",
  "11月",
  "12月",
];

// ── View B (River): chronological ────────────────────────
const chronologicalPosts = [...sortedPosts].reverse();

// ── River config & path generation ──────────────────────
const postCount = chronologicalPosts.length;

const desktopCfg: RiverConfig = {
  cardW: 240,
  cardH: 230,
  cardGap: 60,
  riverY: 240,
  amplitude: 80,
  wavelength: 600,
  padding: 600,
  stepSize: 4,
};
const tabletCfg: RiverConfig = {
  cardW: 240,
  cardH: 210,
  cardGap: 50,
  riverY: 220,
  amplitude: 65,
  wavelength: 500,
  padding: 500,
  stepSize: 4,
};
const mobileCfg: RiverConfig = {
  cardW: 170,
  cardH: 180,
  cardGap: 40,
  riverY: 180,
  amplitude: 50,
  wavelength: 400,
  padding: 300,
  stepSize: 20,
};

const twD = totalWidth(postCount, desktopCfg);
const twT = totalWidth(postCount, tabletCfg);
const twM = totalWidth(postCount, mobileCfg);

const pathMainD = buildRiverPath(twD, desktopCfg);
const pathMainT = buildRiverPath(twT, tabletCfg);
const pathMainM = buildRiverPath(twM, mobileCfg);

const pathBotD = buildRiverPath(twD, desktopCfg, 12);
const pathBotT = buildRiverPath(twT, tabletCfg, 12);
const pathBotM = buildRiverPath(twM, mobileCfg, 12);

const cardsD = cardPositions(postCount, desktopCfg);
const cardsT = cardPositions(postCount, tabletCfg);
const cardsM = cardPositions(postCount, mobileCfg);

const pathLenD = estimatePathLength(pathMainD);

const riverD = makeRiverData(desktopCfg, twD, pathMainD, pathBotD, cardsD);
const riverT = makeRiverData(tabletCfg, twT, pathMainT, pathBotT, cardsT);
const riverM = makeRiverData(mobileCfg, twM, pathMainM, pathBotM, cardsM);

const sparklesD = sparklePositions(pathMainD, 20);
const floatingD = floatingParticles(pathMainD, 10);

const thisYearPostCount = groupedByYear.get(years[0])?.reduce((s, m) => s + m.posts.length, 0) || 0;
---

<Layout title="归档">
  <div class="mx-auto max-w-4xl">
    <header class="mb-6">
      <div class="flex items-end justify-between">
        <div>
          <h1 class="text-2xl font-bold">文章归档</h1>
          <p class="mt-1 text-sm text-75">
            共 {sortedPosts.length} 篇文章 · {years.length} 个年份
          </p>
        </div>
      </div>
      <div class="page-header-divider"></div>
    </header>

    <ArchiveViewTabs />
    <ArchiveStats
      postCount={sortedPosts.length}
      yearCount={years.length}
      latestYear={sortedPosts.length > 0 ? years[0] : 0}
      thisYearPostCount={thisYearPostCount}
    />
    <ArchiveYearNav years={years} />

    <TimelineView years={years} groupedByYear={groupedByYear} monthNames={MONTH_NAMES} />

    <RiverView
      chronologicalPosts={chronologicalPosts}
      cardsD={cardsD}
      riverD={riverD}
      twD={twD}
      twT={twT}
      twM={twM}
      pathLenD={pathLenD}
      sparklesD={sparklesD}
      floatingD={floatingD}
    />
  </div>
</Layout>

<style>
  /* ============================================================
     Reduced motion
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .river-path-animate {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
    .river-card-v2 {
      animation: none !important;
      opacity: 1 !important;
    }
    .river-card-v2:hover .river-card-glass {
      transform: none !important;
    }
    .river-card-v2:hover .river-card-cover img {
      transform: none !important;
    }
    .archive-year-ring {
      transition: none !important;
    }
    .river-particles {
      display: none !important;
    }
    .river-flow-shimmer {
      animation: none !important;
      display: none !important;
    }
    .river-glow-layer {
      animation: none !important;
      opacity: 0.3 !important;
    }
    .river-sparkles {
      display: none !important;
    }
    .river-node-group circle[fill="none"] {
      display: none !important;
    }
  }
</style>

<script>
  import { bindTabHandlers, restoreSavedView } from "../scripts/archive/tabs";
  import { setupRingObserver, cleanupRingObserver } from "../scripts/archive/timeline-observer";
  import { setupRiverDrag, cleanupRiverDrag } from "../scripts/archive/river-drag";
  import { applyArchiveFilter } from "../scripts/archive/filter";

  function initArchive(): void {
    cleanupRingObserver();
    cleanupRiverDrag();
    bindTabHandlers();
    restoreSavedView();
    setupRingObserver();
    setupRiverDrag();
    applyArchiveFilter();
  }

  initArchive();
  document.addEventListener("astro:after-swap", initArchive);
</script>
