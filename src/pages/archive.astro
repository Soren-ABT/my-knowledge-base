---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { normalizeSlug } from "../utils/slug";

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const sortedPosts = allPosts.sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf(),
);

// ── View A (Timeline): year → month → posts ─────────────
type MonthGroup = { month: number; posts: typeof sortedPosts };
const groupedByYear = new Map<number, MonthGroup[]>();
for (const post of sortedPosts) {
  const year = post.data.published.getFullYear();
  const month = post.data.published.getMonth();
  if (!groupedByYear.has(year)) groupedByYear.set(year, []);
  const months = groupedByYear.get(year)!;
  let mg = months.find((m) => m.month === month);
  if (!mg) { mg = { month, posts: [] }; months.push(mg); }
  mg.posts.push(post);
}
for (const months of groupedByYear.values()) {
  months.sort((a, b) => b.month - a.month);
}

const years = Array.from(groupedByYear.keys()).sort((a, b) => b - a);
const MONTH_NAMES = ["1月","2月","3月","4月","5月","6月","7月","8月","9月","10月","11月","12月"];

// ── View B (River): chronological ────────────────────────
const chronologicalPosts = [...sortedPosts].reverse();
const riverYears = Array.from(new Set(chronologicalPosts.map(p => p.data.published.getFullYear()))).sort((a, b) => a - b);

// ── River config & path generation ──────────────────────
interface RiverConfig {
  cardW: number; cardH: number; cardGap: number;
  riverY: number; amplitude: number; wavelength: number;
  padding: number; stepSize: number;
}

const desktopCfg: RiverConfig = { cardW: 240, cardH: 230, cardGap: 60, riverY: 240, amplitude: 80, wavelength: 600, padding: 600, stepSize: 4 };
const tabletCfg: RiverConfig  = { cardW: 240, cardH: 210, cardGap: 50, riverY: 220, amplitude: 65, wavelength: 500, padding: 500, stepSize: 4 };
const mobileCfg: RiverConfig  = { cardW: 170, cardH: 180, cardGap: 40, riverY: 180, amplitude: 50, wavelength: 400, padding: 300, stepSize: 20 };

function buildRiverPath(totalWidth: number, cfg: RiverConfig, offsetY = 0): string {
  const { riverY, amplitude, wavelength, stepSize } = cfg;
  const parts: string[] = [];
  const steps = Math.max(1, Math.ceil(totalWidth / stepSize));
  for (let i = 0; i <= steps; i++) {
    const x = (i / steps) * totalWidth;
    const y = riverY
      + amplitude * 0.5 * Math.sin((x / wavelength) * Math.PI * 2)
      + amplitude * 0.3 * Math.sin((x / (wavelength * 0.6)) * Math.PI * 2 + 1)
      + amplitude * 0.2 * Math.sin((x / (wavelength * 1.5)) * Math.PI * 2 + 2.5);
    parts.push(`${i === 0 ? "M" : "L"} ${x.toFixed(1)} ${(y + offsetY).toFixed(1)}`);
  }
  return parts.join(" ");
}

function totalW(posts: typeof chronologicalPosts, cfg: RiverConfig): number {
  return cfg.padding * 2 + posts.length * (cfg.cardW + cfg.cardGap) - cfg.cardGap;
}

interface CardPos { x: number; y: number; cx: number; waveY: number; isAbove: boolean; }

function cardPositions(posts: typeof chronologicalPosts, cfg: RiverConfig): CardPos[] {
  const offset = 50;
  return posts.map((_, i) => {
    const x = cfg.padding + i * (cfg.cardW + cfg.cardGap);
    const cx = x + cfg.cardW / 2;
    const { riverY, amplitude, wavelength } = cfg;
    const waveY = riverY
      + amplitude * 0.5 * Math.sin((cx / wavelength) * Math.PI * 2)
      + amplitude * 0.3 * Math.sin((cx / (wavelength * 0.6)) * Math.PI * 2 + 1)
      + amplitude * 0.2 * Math.sin((cx / (wavelength * 1.5)) * Math.PI * 2 + 2.5);
    const isAbove = i % 2 === 0;
    const y = isAbove ? waveY - offset - cfg.cardH : waveY + offset;
    return { x, y, cx, waveY, isAbove };
  });
}

function estimatePathLength(d: string): number {
  const pts = d.replace(/^M\s*/, "").split(/ L\s*/).map(p => p.split(" ").map(Number));
  let len = 0;
  for (let i = 1; i < pts.length; i++) {
    len += Math.sqrt((pts[i][0] - pts[i - 1][0]) ** 2 + (pts[i][1] - pts[i - 1][1]) ** 2);
  }
  return Math.round(len);
}

function sparklePositions(mainP: string, count: number): { x: number; y: number }[] {
  const pts = mainP.replace(/^M\s*/, "").split(/ L\s*/).map(p => p.split(" ").map(Number));
  const result: { x: number; y: number }[] = [];
  const step = Math.max(1, Math.floor(pts.length / count));
  for (let i = 0; i < count; i++) {
    const idx = Math.min(i * step, pts.length - 1);
    result.push({ x: pts[idx][0], y: pts[idx][1] + (Math.random() - 0.5) * 16 });
  }
  return result;
}

function floatingParticles(mainP: string, count: number): { x: number; y: number; delay: number; dur: number }[] {
  const pts = mainP.replace(/^M\s*/, "").split(/ L\s*/).map(p => p.split(" ").map(Number));
  const result: { x: number; y: number; delay: number; dur: number }[] = [];
  const step = Math.max(1, Math.floor(pts.length / count));
  for (let i = 0; i < count; i++) {
    const idx = Math.min(i * step + (i % 3) * 7, pts.length - 1);
    result.push({
      x: pts[idx][0] + (Math.random() - 0.5) * 30,
      y: pts[idx][1] + (Math.random() - 0.5) * 20,
      delay: Math.random() * 4,
      dur: 3 + Math.random() * 4,
    });
  }
  return result;
}

// Generate paths for all 3 breakpoints
const twD = totalW(chronologicalPosts, desktopCfg);
const twT = totalW(chronologicalPosts, tabletCfg);
const twM = totalW(chronologicalPosts, mobileCfg);

const pathMainD = buildRiverPath(twD, desktopCfg);
const pathMainT = buildRiverPath(twT, tabletCfg);
const pathMainM = buildRiverPath(twM, mobileCfg);

const pathBotD = buildRiverPath(twD, desktopCfg, 12);
const pathBotT = buildRiverPath(twT, tabletCfg, 12);
const pathBotM = buildRiverPath(twM, mobileCfg, 12);

const cardsD = cardPositions(chronologicalPosts, desktopCfg);
const cardsT = cardPositions(chronologicalPosts, tabletCfg);
const cardsM = cardPositions(chronologicalPosts, mobileCfg);

const pathLenD = estimatePathLength(pathMainD);

interface RiverData {
  tw: number; svgH: number; mainP: string; botP: string; cards: CardPos[];
}
function mkRiver(cfg: RiverConfig, tw: number, mainP: string, botP: string, cards: CardPos[]): RiverData {
  return { tw, svgH: cfg.riverY + cfg.amplitude + cfg.cardH + 220, mainP, botP, cards };
}
const riverD = mkRiver(desktopCfg, twD, pathMainD, pathBotD, cardsD);
const riverT = mkRiver(tabletCfg, twT, pathMainT, pathBotT, cardsT);
const riverM = mkRiver(mobileCfg, twM, pathMainM, pathBotM, cardsM);

const sparklesD = sparklePositions(pathMainD, 20);
const floatingD = floatingParticles(pathMainD, 10);

// ── Category color system ────────────────────────────────
function getCatColor(cat: string): string {
  const map: Record<string, string> = {
    '技术': '#22d3ee', '生活': '#a78bfa', '学术': '#fbbf24',
    '随笔': '#f472b6', '项目': '#34d399', '教程': '#60a5fa',
  };
  if (map[cat]) return map[cat];
  let h = 0;
  for (let i = 0; i < cat.length; i++) h = ((h << 5) - h) + cat.charCodeAt(i);
  return `oklch(0.65 0.16 ${Math.abs(h % 360)})`;
}

function getCatBg(cat: string): string {
  const c = getCatColor(cat);
  return c.replace('0.65', '0.5').replace('0.16', '0.10');
}
---

<Layout title="归档">
  <div class="mx-auto max-w-4xl">
    <header class="mb-6">
      <div class="flex items-end justify-between">
        <div>
          <h1 class="text-2xl font-bold">文章归档</h1>
          <p class="mt-1 text-sm text-75">
            共 {sortedPosts.length} 篇文章 · {years.length} 个年份
          </p>
        </div>
      </div>
      <div class="page-header-divider"></div>
    </header>

    <!-- View toggle tabs -->
    <nav class="archive-tabs mb-8" aria-label="归档视图切换">
      <button class="archive-tab active" data-view="timeline" aria-pressed="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="20" x2="12" y2="4"/><polyline points="6,10 12,4 18,10"/></svg>
        时间线
      </button>
      <button class="archive-tab" data-view="river" aria-pressed="false">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4,17 8,11 12,15 16,9 20,13"/><circle cx="4" cy="17" r="1.5"/><circle cx="8" cy="11" r="1.5"/><circle cx="12" cy="15" r="1.5"/><circle cx="16" cy="9" r="1.5"/><circle cx="20" cy="13" r="1.5"/></svg>
        时间河
      </button>
    </nav>

    <!-- Stats -->
    <div class="stats-grid mb-10">
      <div class="stat-card">
        <span class="stat-number">{sortedPosts.length}</span>
        <span class="stat-label">文章总数</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{years.length}</span>
        <span class="stat-label">年份跨度</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{sortedPosts.length > 0 ? years[0] : '—'}</span>
        <span class="stat-label">最近年份</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{groupedByYear.get(years[0])?.reduce((s, m) => s + m.posts.length, 0) || 0}</span>
        <span class="stat-label">今年文章</span>
      </div>
    </div>

    <!-- Year jump navigation -->
    <nav class="mb-10 flex flex-wrap gap-2" aria-label="年份快速跳转">
      {years.map((year) => (
        <a href={`#year-${year}`} class="inline-flex items-center rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] px-3 py-1.5 text-xs font-medium text-[var(--color-text-secondary)] no-underline transition-all hover:border-[var(--color-primary)] hover:text-[var(--color-primary)]">
          {year}
        </a>
      ))}
    </nav>

    <!-- ================================================================
         View A: Timeline (Fuwari-style vertical + Kirameku polish)
         ================================================================ -->
    <div id="archive-view-timeline" class="archive-view active">
      <div class="archive-timeline-card px-6 py-6 md:px-8">
        {
          years.map((year) => {
            const months = groupedByYear.get(year)!;
            const yearPosts = months.flatMap((m) => m.posts).sort(
              (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
            );
            const yearPostCount = yearPosts.length;

            return (
              <section id={`year-${year}`} class="archive-year-section">
                <div class="archive-year-row">
                  <div class="archive-year-label text-75">{year}</div>
                  <div class="archive-year-dot-col">
                    <div class="archive-year-ring"></div>
                  </div>
                  <div class="archive-year-count text-50">
                    {yearPostCount} 篇文章
                  </div>
                </div>

                {months.map(({ month, posts }) => (
                  <div class="archive-month-group">
                    <div class="archive-month-label">{MONTH_NAMES[month]}</div>

                    {posts.map((post) => {
                      const slug = normalizeSlug(post.id);
                      return (
                        <a
                          href={`/posts/${slug}/`}
                          class="archive-post-item group"
                          data-tags={post.data.tags.join(",")}
                          data-category={post.data.category || ""}
                        >
                          <time datetime={post.data.published.toISOString()} class="archive-post-date text-50">
                            {String(post.data.published.getMonth() + 1).padStart(2, "0")}-{String(post.data.published.getDate()).padStart(2, "0")}
                          </time>
                          <div class="archive-post-dot-col dash-line">
                            <div class="archive-post-dot"></div>
                          </div>
                          <span class="archive-post-title text-75">{post.data.title}</span>
                          <span class="archive-post-tags text-30">
                            {post.data.tags.slice(0, 3).map((t) => `#${t}`).join(" ")}
                          </span>
                        </a>
                      );
                    })}
                  </div>
                ))}
              </section>
            );
          })
        }
      </div>
    </div>

    <!-- ================================================================
         View B: Time River — SVG wavy river (Kirameku-style)
         ================================================================ -->
    <div id="archive-view-river" class="archive-view">
      <div class="river-viewport" id="river-viewport">
        <div class="river-drag-container" id="river-drag-container">
          <svg
            id="river-svg"
            class="river-svg"
            data-plen-desktop={String(pathLenD)}
            data-tw-desktop={String(twD)}
            data-tw-tablet={String(twT)}
            data-tw-mobile={String(twM)}
            width={String(twD)}
            height={String(riverD.svgH)}
            viewBox={`0 -100 ${twD} ${riverD.svgH}`}
            preserveAspectRatio="xMidYMid meet"
            aria-hidden="true"
          >
            <defs>
              <linearGradient id="river-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="var(--primary-light)" stop-opacity="0" />
                <stop offset="5%" stop-color="var(--primary-light)" stop-opacity="0.5" />
                <stop offset="50%" stop-color="var(--primary)" stop-opacity="0.6" />
                <stop offset="95%" stop-color="var(--primary-light)" stop-opacity="0.5" />
                <stop offset="100%" stop-color="var(--primary-light)" stop-opacity="0" />
              </linearGradient>
              <linearGradient id="river-grad-dim" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="var(--primary-light)" stop-opacity="0" />
                <stop offset="5%" stop-color="var(--primary-light)" stop-opacity="0.3" />
                <stop offset="50%" stop-color="var(--primary)" stop-opacity="0.4" />
                <stop offset="95%" stop-color="var(--primary-light)" stop-opacity="0.3" />
                <stop offset="100%" stop-color="var(--primary-light)" stop-opacity="0" />
              </linearGradient>
              <filter id="river-glow" x="-5%" y="-20%" width="110%" height="140%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="6" />
              </filter>
              <filter id="dot-glow" x="-100%" y="-100%" width="300%" height="300%">
                <feGaussianBlur in="SourceGraphic" stdDeviation="3" />
              </filter>
            </defs>

            <!-- River main path -->
            <path id="river-main-path" d={riverD.mainP} fill="none"
              stroke="url(#river-grad)" stroke-width="3" stroke-linecap="round"
              class="river-path-animate"
              style={`--river-path-len: ${pathLenD}`} />

            <!-- River glow layer (desktop) -->
            <path id="river-glow-path" d={riverD.mainP} fill="none"
              stroke="url(#river-grad)" stroke-width="20" stroke-linecap="round"
              filter="url(#river-glow)" opacity="0.3"
              class="river-glow-layer river-path-animate"
              style={`--river-path-len: ${pathLenD}`} />

            <!-- River bottom highlight -->
            <path id="river-bot-path" d={riverD.botP} fill="none"
              stroke="url(#river-grad-dim)" stroke-width="1"
              class="river-path-animate"
              style={`--river-path-len: ${pathLenD}`} />

            <!-- River flow shimmer -->
            <path id="river-shimmer-path" d={riverD.mainP} fill="none"
              stroke="var(--primary-light)" stroke-width="2" stroke-linecap="round"
              opacity="0.12" class="river-flow-shimmer" />

            <!-- Flowing particles (desktop) -->
            <g class="river-particles">
              {/* 6 path-following particles: varied size, speed, color */}
              {[
                { r: 3, dur: 10, delay: 0, fill: 'var(--primary)', opacity: 0.8 },
                { r: 2, dur: 7, delay: 1.5, fill: 'var(--primary-light)', opacity: 0.6 },
                { r: 4, dur: 12, delay: 3, fill: '#ffffff', opacity: 0.7 },
                { r: 2, dur: 6, delay: 5, fill: 'var(--primary)', opacity: 0.55 },
                { r: 3, dur: 9, delay: 2, fill: '#ffffff', opacity: 0.65 },
                { r: 2, dur: 8, delay: 6, fill: 'var(--primary-light)', opacity: 0.5 },
              ].map((p, i) => (
                <circle r={String(p.r)} fill={p.fill} opacity={String(p.opacity)} filter="url(#dot-glow)">
                  <animateMotion dur={`${p.dur}s`} repeatCount="indefinite" begin={`${p.delay}s`}>
                    <mpath href="#river-flow-path" />
                  </animateMotion>
                </circle>
              ))}
              {/* 2 trailing particles (follow behind main particles) */}
              <circle r="1.5" fill="#ffffff" opacity="0.4" filter="url(#dot-glow)">
                <animateMotion dur="10s" repeatCount="indefinite" begin="0.6s">
                  <mpath href="#river-flow-path" />
                </animateMotion>
              </circle>
              <circle r="1.5" fill="var(--primary-light)" opacity="0.35" filter="url(#dot-glow)">
                <animateMotion dur="7s" repeatCount="indefinite" begin="2.1s">
                  <mpath href="#river-flow-path" />
                </animateMotion>
              </circle>
              <path id="river-flow-path" d={riverD.mainP} fill="none" stroke="none" />
            </g>

            {/* Floating ambient particles (rise from river) */}
            <g class="river-particles">
              {floatingD.map((fp) => (
                <circle cx={String(fp.x)} cy={String(fp.y)} r="1.5" fill="var(--primary-light)" opacity="0">
                  <animate attributeName="cy" values={`${fp.y};${fp.y - 40};${fp.y}`} dur={`${fp.dur}s`} begin={`${fp.delay}s`} repeatCount="indefinite" />
                  <animate attributeName="opacity" values="0;0.6;0" dur={`${fp.dur}s`} begin={`${fp.delay}s`} repeatCount="indefinite" />
                </circle>
              ))}
            </g>

            {/* River nodes with ripple effect */}
            {chronologicalPosts.map((_post, i) => {
              const stagger = (i % 3) * 0.8;
              return (
                <g class="river-node-group">
                  {/* Ripple ring 1 */}
                  <circle cx={cardsD[i].cx} cy={cardsD[i].waveY} r="6" fill="none" stroke="#ffffff" opacity="0">
                    <animate attributeName="r" values="6;28" dur="3s" begin={`${stagger}s`} repeatCount="indefinite" />
                    <animate attributeName="opacity" values="0.45;0" dur="3s" begin={`${stagger}s`} repeatCount="indefinite" />
                  </circle>
                  {/* Ripple ring 2 (offset) */}
                  <circle cx={cardsD[i].cx} cy={cardsD[i].waveY} r="6" fill="none" stroke="#ffffff" opacity="0">
                    <animate attributeName="r" values="6;28" dur="3s" begin={`${stagger + 1.5}s`} repeatCount="indefinite" />
                    <animate attributeName="opacity" values="0.45;0" dur="3s" begin={`${stagger + 1.5}s`} repeatCount="indefinite" />
                  </circle>
                  {/* Solid dot */}
                  <circle cx={cardsD[i].cx} cy={cardsD[i].waveY} r="6" fill="#ffffff" />
                  <circle cx={cardsD[i].cx} cy={cardsD[i].waveY} r="10" fill="#ffffff" opacity="0.25" />
                </g>
              );
            })}
            {/* Sparkle dots along the river */}
            <g class="river-sparkles">
              {sparklesD.map((sp, i) => (
                <circle cx={String(sp.x)} cy={String(sp.y)} r="1.5" fill="#ffffff"
                  class="river-sparkle"
                  style={`animation-delay: ${(i * 0.25).toFixed(2)}s`} />
              ))}
            </g>
          </svg>

          <!-- Card overlay -->
          <div class="river-cards-layer" id="river-cards-layer">
            {chronologicalPosts.map((post, i) => {
              const cp = cardsD[i];
              const slug = post.id.replace(/\.(md|mdx)$/, "").replace(/\/index$/, "");
              const cat = post.data.category || "";
              const catColor = cat ? getCatColor(cat) : 'var(--border-color)';
              return (
                <a
                  href={`/posts/${slug}/`}
                  class={`river-card-v2 ${cp.isAbove ? 'above' : 'below'}`}
                  data-category={cat}
                  data-tags={post.data.tags.join(',')}
                  data-river-index={String(i)}
                  style={`--card-x: ${cp.x}px; --card-y: ${cp.y}px; --card-idx: ${i}`}
                >
                  <svg class="river-card-connector" aria-hidden="true"
                    style={`position:absolute; top:${cp.isAbove ? '100%' : '-2rem'}; left:50%; width:2px; height:2rem; transform:translateX(-50%); overflow:visible; pointer-events:none;`}
                  >
                    <line x1="1" y1="0" x2="1" y2="100%"
                      stroke={catColor} stroke-width="1.5" opacity="0.4"
                      stroke-dasharray="4 3" />
                  </svg>
                  <div class="river-card-glass">
                    {post.data.image ? (
                      <div class="river-card-cover">
                        <img src={post.data.image} alt="" loading="lazy" />
                        <div class="river-card-cover-date">
                          {String(post.data.published.getMonth() + 1).padStart(2, "0")}-{String(post.data.published.getDate()).padStart(2, "0")}
                        </div>
                      </div>
                    ) : (
                      <div class="river-card-no-cover">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.3"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        <span class="river-card-cover-date" style="color:var(--text-muted)">
                          {String(post.data.published.getMonth() + 1).padStart(2, "0")}-{String(post.data.published.getDate()).padStart(2, "0")}
                        </span>
                      </div>
                    )}
                    <div class="river-card-content">
                      <h3 class="river-card-title">{post.data.title}</h3>
                      {post.data.description && (
                        <p class="river-card-desc">{post.data.description}</p>
                      )}
                      <div class="river-card-footer">
                        {cat && (
                          <span class="river-card-cat" style={`background:${getCatBg(cat)}; color:${catColor}`}>
                            {cat}
                          </span>
                        )}
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* ============================================================
     Archive View Tabs
     ============================================================ */
  .archive-tabs {
    display: flex;
    gap: 0.25rem;
    padding: 0.25rem;
    border-radius: 0.75rem;
    background: var(--card-bg-alt);
    border: 1px solid var(--border-color);
    width: fit-content;
  }

  .archive-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 0.6rem;
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .archive-tab:hover {
    color: var(--text-secondary);
    background: var(--btn-plain-bg-hover);
  }

  .archive-tab.active {
    background: var(--card-bg);
    color: var(--primary);
    box-shadow: var(--shadow-sm);
  }

  /* ── View visibility ──────────────────────────────────── */
  .archive-view { display: none; }
  .archive-view.active { display: block; }

  /* ============================================================
     View A — Timeline (Kirameku-polished)
     ============================================================ */

  /* Glass-morphism card container */
  .archive-timeline-card {
    background: var(--card-bg);
    border-radius: var(--radius-large);
    border: 1px solid var(--border-color);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  body.wallpaper-transparent .archive-timeline-card {
    background: rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border-color: rgba(255, 255, 255, 0.4);
  }
  body.wallpaper-transparent:is(.dark) .archive-timeline-card {
    background-color: rgba(30, 41, 59, 0.6);
    border-color: rgba(255, 255, 255, 0.1);
  }

  /* Year row */
  .archive-year-row {
    display: flex;
    align-items: center;
    width: 100%;
    height: 3.75rem;
  }
  .archive-year-label {
    width: 15%;
    text-align: right;
    font-size: 1.5rem;
    font-weight: 700;
    padding-right: 0.5rem;
  }
  .archive-year-dot-col {
    width: 15%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .archive-year-ring {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 9999px;
    background: transparent;
    outline: 3px solid var(--primary);
    outline-offset: -2px;
    z-index: 50;
    transition: outline-color 0.3s ease, transform 0.3s ease;
  }
  .archive-year-section.in-view .archive-year-ring {
    outline-color: var(--primary);
    transform: scale(1.3);
  }
  .archive-year-count {
    width: 70%;
    text-align: left;
    font-size: 0.85rem;
    padding-left: 0.5rem;
  }

  /* Post item */
  .archive-post-item {
    display: flex;
    align-items: center;
    width: 100%;
    height: 2.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: background-color 0.15s ease, transform 0.2s ease;
  }
  .archive-post-item:hover { background-color: var(--btn-plain-bg-hover); transform: translateX(0.25rem); }
  .archive-post-item:active { background-color: var(--btn-plain-bg-active); }

  .archive-post-date {
    width: 15%;
    flex-shrink: 0;
    text-align: right;
    font-size: 0.8rem;
    font-family: "JetBrains Mono Variable", "JetBrainsMonoNerdFont", monospace;
    padding-right: 0.5rem;
    tabular-nums: true;
  }
  .archive-post-dot-col {
    width: 15%;
    flex-shrink: 0;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .archive-post-dot {
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: oklch(0.5 0.05 var(--hue));
    outline: 4px solid var(--card-bg);
    z-index: 50;
    transition: all 0.2s ease;
  }
  .archive-post-item:hover .archive-post-dot {
    height: 20px;
    background: var(--primary);
    outline-color: var(--btn-plain-bg-hover);
  }
  .archive-post-item:active .archive-post-dot {
    outline-color: var(--btn-plain-bg-active);
  }
  .archive-post-title {
    flex: 1;
    min-width: 0;
    font-weight: 600;
    font-size: 0.88rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    padding-right: 2rem;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .archive-post-item:hover .archive-post-title {
    transform: translateX(0.25rem);
    color: var(--primary);
  }
  .archive-post-tags {
    width: 15%;
    flex-shrink: 0;
    font-size: 0.8rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Month labels */
  .archive-month-group { margin-top: 0.25rem; }
  .archive-month-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin: 0.5rem 0 0.25rem 0;
    padding-left: calc(30% + 0.5rem);
  }

  /* ============================================================
     View B — SVG Time River (Kirameku-style)
     ============================================================ */

  .river-viewport {
    overflow-x: auto;
    overflow-y: hidden;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 2rem 0;
    margin: 0 calc(-50vw + 50%);
    padding-left: calc(50vw - 50%);
    padding-right: calc(50vw - 50%);
  }
  .river-viewport::-webkit-scrollbar { display: none; }
  .river-viewport:active { cursor: grabbing; }

  .river-drag-container {
    position: relative;
    min-width: max-content;
  }

  /* SVG */
  .river-svg {
    display: block;
    overflow: visible;
    position: relative;
    z-index: 0;
  }

  /* River draw-in animation */
  .river-path-animate {
    stroke-dasharray: var(--river-path-len, 5000);
    stroke-dashoffset: var(--river-path-len, 5000);
    animation: river-draw-in 1.8s ease-in-out forwards;
  }

  @keyframes river-draw-in {
    from { stroke-dashoffset: var(--river-path-len, 5000); }
    to   { stroke-dashoffset: 0; }
  }

  /* River flow shimmer */
  .river-flow-shimmer {
    animation: river-shimmer 3s linear infinite;
  }
  @keyframes river-shimmer {
    to { stroke-dashoffset: -120; }
  }

  /* Glow breathing pulse */
  .river-glow-layer {
    animation: glow-pulse 4s ease-in-out infinite;
  }
  @keyframes glow-pulse {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.4; }
  }

  /* Sparkle dots */
  .river-sparkle {
    opacity: 0;
    animation: sparkle-blink 2.5s ease-in-out infinite;
  }
  @keyframes sparkle-blink {
    0%, 100% { opacity: 0; transform: scale(0.5); }
    30% { opacity: 0.8; transform: scale(1.2); }
    60% { opacity: 0; transform: scale(0.5); }
  }

  /* Glow, particles, shimmer, sparkles hidden on mobile */
  @media (max-width: 767px) {
    .river-glow-layer,
    .river-particles,
    .river-flow-shimmer,
    .river-sparkles { display: none; }
  }

  /* ── Card overlay ─────────────────────────────────────── */
  .river-cards-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .river-card-v2 {
    position: absolute;
    left: var(--card-x, 0px);
    top: var(--card-y, 0px);
    width: 240px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    user-select: none;
    pointer-events: auto;
    content-visibility: auto;
    contain-intrinsic-size: 240px 280px;
    animation: river-card-in 0.45s ease both;
    animation-delay: calc(var(--card-idx, 0) * 60ms);
  }

  .river-card-v2.above { flex-direction: column; }
  .river-card-v2.below { flex-direction: column-reverse; }

  @keyframes river-card-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Glass card body */
  .river-card-glass {
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    cursor: pointer;
  }

  body.wallpaper-transparent .river-card-glass {
    background: rgba(255, 255, 255, 0.6);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    border-color: rgba(255, 255, 255, 0.4);
  }
  body.wallpaper-transparent:is(.dark) .river-card-glass {
    background: rgba(30, 41, 59, 0.7);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .river-card-v2:hover .river-card-glass {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary);
  }

  /* Cover image */
  .river-card-cover {
    height: 100px;
    overflow: hidden;
    position: relative;
  }
  .river-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .river-card-v2:hover .river-card-cover img {
    transform: scale(1.1);
  }
  .river-card-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.35), transparent 60%);
  }
  .river-card-cover-date {
    position: absolute;
    bottom: 4px;
    left: 8px;
    font-size: 0.6rem;
    color: rgba(255,255,255,0.8);
    z-index: 1;
  }

  /* No-cover placeholder */
  .river-card-no-cover {
    height: 100px;
    background: linear-gradient(135deg, var(--card-bg-alt), var(--card-bg));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    position: relative;
  }

  /* Card text */
  .river-card-content {
    padding: 0.65rem 0.75rem;
  }
  .river-card-title {
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 0.2rem 0;
    transition: color 0.15s ease;
  }
  .river-card-v2:hover .river-card-title {
    color: var(--primary);
  }
  .river-card-desc {
    font-size: 0.65rem;
    color: var(--text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 0.4rem 0;
  }
  .river-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .river-card-cat {
    display: inline-block;
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    border-radius: 9999px;
    font-weight: 500;
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (min-width: 768px) {
    .archive-year-label { width: 10%; }
    .archive-year-dot-col { width: 10%; }
    .archive-year-count { width: 80%; }
    .archive-post-date { width: 10%; }
    .archive-post-dot-col { width: 10%; }
    .archive-post-title { max-width: 65%; }
    .archive-post-tags { width: 15%; }
    .archive-month-label { padding-left: calc(20% + 0.5rem); }
  }

  @media (max-width: 767px) {
    .archive-post-tags { display: none; }
    .archive-post-title { width: 70%; font-size: 0.82rem; padding-right: 0.5rem; }
    .archive-post-date { font-size: 0.72rem; }
    .archive-month-label { padding-left: calc(30% + 0.5rem); }
    .river-card-v2 { width: 170px; }
    .river-card-cover,
    .river-card-no-cover { height: 70px; }
    .river-card-title { font-size: 0.7rem; }
    .river-card-desc { font-size: 0.6rem; }
    .river-viewport { margin: 0 -1rem; padding-left: 1rem; padding-right: 1rem; }
  }

  /* ============================================================
     Reduced motion
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .river-path-animate {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
    .river-card-v2 {
      animation: none !important;
      opacity: 1 !important;
    }
    .river-card-v2:hover .river-card-glass {
      transform: none !important;
    }
    .river-card-v2:hover .river-card-cover img {
      transform: none !important;
    }
    .archive-year-ring { transition: none !important; }
    .river-particles { display: none !important; }
    .river-flow-shimmer { animation: none !important; display: none !important; }
    .river-glow-layer { animation: none !important; opacity: 0.3 !important; }
    .river-sparkles { display: none !important; }
    .river-node-group circle[fill="none"] { display: none !important; }
  }
</style>

<script>
  // --- Cleanup tracking (module scope, persists across SPA navigations) ---
  let _ringObserver: IntersectionObserver | null = null;
  let _dragCleanup: (() => void) | null = null;

  // ============================================================
  // Tab switching
  // ============================================================
  function switchArchiveView(viewName: string): void {
    document.querySelectorAll<HTMLElement>(".archive-tab").forEach((btn) => {
      const isActive = btn.dataset.view === viewName;
      btn.classList.toggle("active", isActive);
      btn.setAttribute("aria-pressed", String(isActive));
    });
    document.querySelectorAll<HTMLElement>(".archive-view").forEach((view) => {
      view.classList.toggle("active", view.id === `archive-view-${viewName}`);
    });
    try { localStorage.setItem("archive-view", viewName); } catch (e) { /* noop */ }
  }

  // ============================================================
  // Cleanup stale observers / listeners from previous SPA visit
  // ============================================================
  function cleanupArchive(): void {
    if (_ringObserver) {
      _ringObserver.disconnect();
      _ringObserver = null;
    }
    if (_dragCleanup) {
      _dragCleanup();
      _dragCleanup = null;
    }
  }

  // ============================================================
  // Tab click binding
  // ============================================================
  function bindTabHandlers(): void {
    document.querySelectorAll<HTMLElement>(".archive-tab").forEach((btn) => {
      btn.addEventListener("click", () => switchArchiveView(btn.dataset.view!));
    });
  }

  // ============================================================
  // localStorage restoration
  // ============================================================
  function restoreSavedView(): void {
    const savedView = (() => { try { return localStorage.getItem("archive-view"); } catch (e) { return null; } })();
    if (savedView === "river") switchArchiveView("river");
  }

  // ============================================================
  // View A — Year ring IntersectionObserver
  // ============================================================
  function setupRingObserver(): void {
    _ringObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        (entry.target as HTMLElement).classList.toggle('in-view', entry.isIntersecting);
      });
    }, { rootMargin: '-80px 0px' });

    document.querySelectorAll<HTMLElement>('.archive-year-section').forEach((s) => _ringObserver!.observe(s));
  }

  // ============================================================
  // View B — SVG River: drag with momentum
  // ============================================================
  function setupRiverDrag(): void {
    const viewport = document.getElementById("river-viewport");
    if (!viewport) return;

    let isDragging = false;
    let didDrag = false;
    let startX = 0;
    let scrollStart = 0;
    let velocityX = 0;
    let prevX = 0;
    let timestamp = 0;
    let momentumRAF: number | null = null;
    const FRICTION = 0.92;
    const MIN_VELOCITY = 0.5;
    const DRAG_MULTIPLIER = 1.5;

    function startDrag(clientX: number): void {
      isDragging = true;
      didDrag = false;
      startX = clientX;
      scrollStart = viewport!.scrollLeft;
      velocityX = 0;
      prevX = clientX;
      timestamp = performance.now();
      cancelMomentum();
      viewport!.classList.add("dragging");
    }

    function moveDrag(clientX: number): void {
      if (!isDragging) return;
      const now = performance.now();
      const dt = now - timestamp;
      if (dt > 0) velocityX = (clientX - prevX) / dt;
      prevX = clientX;
      timestamp = now;
      const dx = (startX - clientX) * DRAG_MULTIPLIER;
      viewport!.scrollLeft = scrollStart + dx;
      if (Math.abs(clientX - startX) > 3) didDrag = true;
    }

    function endDrag(): void {
      if (!isDragging) return;
      isDragging = false;
      viewport!.classList.remove("dragging");
      startMomentum();
    }

    function startMomentum(): void {
      cancelMomentum();
      if (Math.abs(velocityX) < MIN_VELOCITY) return;
      let lastTime = performance.now();

      function tick(now: number): void {
        const dt = now - lastTime;
        lastTime = now;
        velocityX *= FRICTION;
        if (Math.abs(velocityX) < MIN_VELOCITY) { cancelMomentum(); return; }
        viewport!.scrollLeft += velocityX * dt;
        const maxScroll = viewport!.scrollWidth - viewport!.clientWidth;
        viewport!.scrollLeft = Math.max(0, Math.min(maxScroll, viewport!.scrollLeft));
        if (viewport!.scrollLeft <= 0 || viewport!.scrollLeft >= maxScroll) {
          if (Math.abs(velocityX) < MIN_VELOCITY * 2) { cancelMomentum(); return; }
        }
        momentumRAF = requestAnimationFrame(tick);
      }
      momentumRAF = requestAnimationFrame(tick);
    }

    function cancelMomentum(): void {
      if (momentumRAF) { cancelAnimationFrame(momentumRAF); momentumRAF = null; }
      velocityX = 0;
    }

    // Named handler references for removeEventListener
    const handleMouseDown = (e: MouseEvent) => startDrag(e.clientX);
    const handleMouseMove = (e: MouseEvent) => { if (isDragging) moveDrag(e.clientX); };
    const handleMouseUp   = () => { if (isDragging) endDrag(); };
    const handleTouchStart = (e: TouchEvent) => { if (e.touches.length === 1) startDrag(e.touches[0].clientX); };
    const handleTouchMove  = (e: TouchEvent) => {
      if (isDragging && e.touches.length === 1) { e.preventDefault(); moveDrag(e.touches[0].clientX); }
    };
    const handleTouchEnd = () => { endDrag(); };

    viewport.addEventListener("mousedown", handleMouseDown);
    window.addEventListener("mousemove", handleMouseMove);
    window.addEventListener("mouseup", handleMouseUp);
    viewport.addEventListener("touchstart", handleTouchStart, { passive: true });
    viewport.addEventListener("touchmove", handleTouchMove, { passive: false });
    viewport.addEventListener("touchend", handleTouchEnd);

    document.querySelectorAll<HTMLElement>(".river-card-v2").forEach((card) => {
      card.addEventListener("click", function(e) {
        if (didDrag) { e.preventDefault(); e.stopPropagation(); }
      });
    });

    // Store cleanup so old listeners are removed on re-init
    _dragCleanup = () => {
      cancelMomentum();
      viewport.removeEventListener("mousedown", handleMouseDown);
      window.removeEventListener("mousemove", handleMouseMove);
      window.removeEventListener("mouseup", handleMouseUp);
      viewport.removeEventListener("touchstart", handleTouchStart);
      viewport.removeEventListener("touchmove", handleTouchMove);
      viewport.removeEventListener("touchend", handleTouchEnd);
    };
  }

  // ============================================================
  // Tag/category filtering (both views)
  // ============================================================
  function applyArchiveFilter(): void {
    const params = new URLSearchParams(window.location.search);
    const filterTags = params.getAll("tag");
    const filterCategory = params.get("category");
    if (filterTags.length === 0 && !filterCategory) return;

    document.querySelectorAll<HTMLElement>(".archive-post-item, .river-card-v2").forEach((el) => {
      const elTags = (el.dataset.tags || "").split(",").filter(Boolean);
      const elCat = el.dataset.category || "";
      const tagOk = filterTags.length === 0 || filterTags.some((t) => elTags.includes(t));
      const catOk = !filterCategory || elCat === filterCategory;
      el.style.display = (tagOk && catOk) ? "" : "none";
    });

    document.querySelectorAll<HTMLElement>(".archive-year-section, .river-year-block").forEach((section) => {
      const hasVisible = section.querySelector<HTMLElement>(
        '.archive-post-item:not([style*="display: none"]), .river-card-v2:not([style*="display: none"])'
      );
      if (!hasVisible) section.style.display = "none";
    });
  }

  // ============================================================
  // Orchestration
  // ============================================================
  function initArchive(): void {
    cleanupArchive();
    bindTabHandlers();
    restoreSavedView();
    setupRingObserver();
    setupRiverDrag();
    applyArchiveFilter();
  }

  // --- Boot: first load + every SPA return ---
  initArchive();
  document.addEventListener("astro:after-swap", initArchive);
</script>
