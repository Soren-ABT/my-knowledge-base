---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { normalizeSlug } from "../utils/slug";
import { siteConfig } from "../config";
import { getStrings, interpolate } from "../i18n";

const ui = await getStrings(siteConfig.lang);

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const postsWithImages = allPosts
  .filter((p) => p.data.image && p.data.image.length > 0)
  .sort((a, b) => b.data.published.valueOf() - a.data.published.valueOf());

function hashString(str: string): number {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = (hash << 5) - hash + str.charCodeAt(i);
    hash |= 0;
  }
  return (Math.abs(hash % 7) - 3) * 0.8;
}
---

<Layout title={ui["gallery.title"]}>
  <div class="mx-auto max-w-6xl">
    <header class="mb-10">
      <div class="flex items-end justify-between">
        <div>
          <h1 class="text-2xl font-bold">{ui["gallery.title"]}</h1>
          <p class="mt-1 text-sm text-75">
            {interpolate(ui["gallery.count"], { count: postsWithImages.length })}
          </p>
        </div>
      </div>
      <div class="page-header-divider"></div>
    </header>

    {
      postsWithImages.length > 0 ? (
        <div class="gallery-grid">
          {postsWithImages.map((post, i) => {
            const slug = normalizeSlug(post.id);
            const tilt = hashString(slug);
            return (
              <a
                href={`/posts/${slug}/`}
                class="gallery-photo-card animate-gpu"
                style={`--card-tilt: ${tilt}deg; animation-delay: calc(var(--content-delay) + ${i * 60}ms)`}
                data-gallery-index={String(i)}
                data-gallery-src={post.data.image}
                data-gallery-title={post.data.title}
              >
                <div class="gallery-photo-frame">
                  <div class="gallery-photo-inner">
                    <img src={post.data.image} alt={post.data.title} loading="lazy" />
                  </div>
                </div>
                <div class="gallery-photo-tape" />
                <span class="gallery-photo-title">{post.data.title}</span>
              </a>
            );
          })}
        </div>
      ) : (
        <div class="rounded-lg border border-dashed border-[var(--border-color)] p-12 text-center text-50">
          <p class="text-lg">{ui["gallery.empty"]}</p>
          <p class="mt-2 text-sm">{ui["gallery.emptyHint"]}</p>
        </div>
      )
    }

    <!-- Lightbox -->
    <div id="gallery-lightbox" class="gallery-lb-overlay" role="dialog" aria-label="图片预览" inert>
      <div class="gallery-lb-bg"></div>
      <button class="gallery-lb-close" aria-label="关闭">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <button class="gallery-lb-prev" aria-label="上一张">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="gallery-lb-next" aria-label="下一张">
        <svg
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
      <div class="gallery-lb-image-wrapper">
        <img id="gallery-lb-img" src="" alt="" />
        <div class="gallery-lb-caption"></div>
      </div>
      <div class="gallery-lb-counter"></div>
    </div>
  </div>
</Layout>

<script defer src="/js/gallery-lightbox.js"></script>
