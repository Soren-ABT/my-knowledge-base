---
import Layout from "../layouts/Layout.astro";
---
<Layout title="404 - 页面未找到" withProgressBar={false}>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-6xl font-bold text-[var(--color-primary)]">404</h1>
    <p class="mt-4 text-lg text-[var(--color-text-secondary)]">
      你访问的页面不存在
    </p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-[var(--color-primary)] px-6 py-2.5 text-sm font-medium text-white no-underline transition-opacity hover:opacity-90"
    >
      返回首页
    </a>
  </div>
</Layout>
