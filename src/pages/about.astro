---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { profileConfig } from "../config";
import { getReadingStats } from "../utils/reading-time";

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Count stats
const postCount = allPosts.length;
const allTags = new Set<string>();
allPosts.forEach((p) => p.data.tags.forEach((t) => allTags.add(t)));
const tagCount = allTags.size;

let totalChars = 0;
allPosts.forEach((p) => { if (p.body) totalChars += getReadingStats(p.body).chars; });
---

<Layout title="关于">
  <div class="mx-auto max-w-4xl">
    <!-- Page header -->
    <header class="mb-10">
      <h1 class="text-2xl font-bold">关于</h1>
      <p class="mt-1 text-sm text-[var(--color-text-secondary)]">了解更多关于我和这个站点</p>
      <div class="page-header-divider"></div>
    </header>

    <!-- Profile card -->
    <div class="card-base mb-10 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-6 sm:p-8">
      <div class="flex flex-col items-start gap-6 sm:flex-row">
        {profileConfig.avatar ? (
          <img
            src={profileConfig.avatar}
            alt={profileConfig.name}
            class="h-24 w-24 rounded-full ring-2 ring-[var(--color-border)] shadow-md"
          />
        ) : (
          <div class="flex h-24 w-24 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--progress-color-end)] text-3xl font-bold text-white shadow-md">
            {profileConfig.name.charAt(0)}
          </div>
        )}
        <div class="flex-1">
          <h2 class="text-xl font-bold">{profileConfig.name}</h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-secondary)]">
            {profileConfig.bio}
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            {profileConfig.links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-regular rounded-lg px-4 py-1.5 text-sm"
              >
                {link.icon === 'github' && (
                  <svg class="mr-1.5 inline-block h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                )}
                {link.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Stats grid -->
    <div class="stats-grid mb-10">
      <div class="stat-card">
        <span class="stat-number">{postCount}</span>
        <span class="stat-label">文章总数</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{tagCount}</span>
        <span class="stat-label">标签分类</span>
      </div>
      <div class="stat-card">
        <span class="stat-number">{totalChars > 10000 ? Math.round(totalChars / 1000) + 'k' : totalChars.toLocaleString()}</span>
        <span class="stat-label">总字数</span>
      </div>
    </div>

    <!-- Tech Stack -->
    <div class="mb-10">
      <h2 class="mb-4 text-lg font-bold">技术栈</h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">Astro 6</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">静态站点生成</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">Tailwind CSS 4</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">原子化 CSS 框架</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">Three.js</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">3D 交互首页</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">MathJax</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">LaTeX 公式渲染</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">GitHub Pages</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">静态资源部署</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">Vercel</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">边缘网络加速</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">Markdown</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">内容创作格式</div>
        </div>
        <div class="stat-card">
          <div class="text-sm font-semibold text-[var(--color-text)]">RSS</div>
          <div class="text-xs text-[var(--color-text-muted)] mt-1">内容订阅分发</div>
        </div>
      </div>
    </div>
  </div>
</Layout>
