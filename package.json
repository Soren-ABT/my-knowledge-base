{
  "name": "personal-blog",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/scan-music.mjs && astro dev",
    "start": "node scripts/scan-music.mjs && astro dev",
    "build": "node scripts/scan-music.mjs && astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "scan-music": "node scripts/scan-music.mjs",
    "scan-music:watch": "node scripts/scan-music.mjs --watch",
    "lint": "eslint \"src/**/*.{ts,js,mjs,cjs,astro}\"",
    "format": "prettier --write \"src/**/*.{astro,ts,js,mjs,cjs,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,js,mjs,cjs,json,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "gen-wallpapers": "node scripts/generate-responsive-wallpapers.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "astro": "^6.4.3",
    "astro-expressive-code": "^0.42.0",
    "hastscript": "^9.0.1",
    "katex": "^0.17.0",
    "mdast-util-to-string": "^4.0.0",
    "music-metadata": "^11.12.3",
    "reading-time": "^1.5.0",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vite-pwa/astro": "^1.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "jsdom": "^29.1.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "ttf2woff2": "^8.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wawoff2": "^2.0.1"
  }
}
